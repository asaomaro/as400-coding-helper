{
  // ユニットテスト用。src とテストを一緒に out-test へ出す。
  // 本体の tsconfig は rootDir が src なのでテストを含められない。
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./out-test",
    "sourceMap": false
  },
  "include": ["src", "test/unit"],
  "exclude": ["node_modules", ".vscode-test", "out", "out-test"]
}
