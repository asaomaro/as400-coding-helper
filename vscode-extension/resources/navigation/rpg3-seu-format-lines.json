{
  "note": "SEU の書式行。RPG III は実機 pub400.com の SEU から実測、DDS は実機のメッセージ・ファイル QEDTMSG から取得したもの。",
  "method": "SEU の書式行(FMT)を実測。F19/F20(Shift+F7/F8)で左右にずらし、1-71 桁と 21-80 桁の2ビューを合成して全80桁を得た。",
  "ddsMethod": "QSYS2.MESSAGE_FILE_DATA を MESSAGE_FILE='QEDTMSG' で検索する。本文は 「4 文字のタグ + 80 桁の書式行 + 81-100 桁（注記域）の目盛り」の 104 文字。書式行は 5-84 文字目。NLS ごとに翻訳版があるため英字表記のものを採る。",
  "templates": {
    "H-SPEC": ".....H........1..CDYI....S..............1.F...............................Pgm-id",
    "F-SPEC": ".....FFilenameIPEAF....RlenLK1AIOvKlocEDevice+......KExit++Entry+A....U1........",
    "E-SPEC": ".....E....FromfileTofile++Name++N/rN/tbLenPDSArrnamLenPDSComments+++++++++......",
    "L-SPEC": ".....LFilename066Fl060Ol........................................................",
    "I-SPEC": ".....IFilenameSqNORiPos1NCCPos2NCCPos3NCC.......................................",
    "C-SPEC": ".....CL0N01N02N03Factor1+++OpcdeFactor2+++ResultLenDHHiLoEqComments+++++++......",
    "O-SPEC-RECORD": ".....OName++++DFBASbSaN01N02N03Excnam...........................................",
    "O-SPEC-FIELD": ".....O................N01N02N03Field+YBEnd+PConstant/editword+++++++++..........",
    "DDS-PF": ".....A..........T.Name++++++RLen++TDpB......Functions+++++++++++++++++++++++++++",
    "DDS-LF": ".....A..........T.Name++++++.Len++TDpB......Functions+++++++++++++++++++++++++++",
    "DDS-DSPF": ".....AAN01N02N03T.Name++++++RLen++TDpBLinPosFunctions+++++++++++++++++++++++++++",
    "DDS-PRTF": ".....AAN01N02N03T.Name++++++RLen++TDpBLinPosFunctions+++++++++++++++++++++++++++"
  }
}
