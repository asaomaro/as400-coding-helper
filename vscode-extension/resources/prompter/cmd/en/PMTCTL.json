{
  "keyword": "PMTCTL",
  "description": "Prompt Control Definition (PMTCTL)",
  "parameters": [
    {
      "name": "CTL",
      "description": "Controlling keyword",
      "help": "Controlling keyword (CTL)\n\nSpecifies the name of the parameter that controls the prompting. The value of the parameter specified here is compared to the value specified in the Controlling conditions (COND) parameter. If the Prompt control program prompt (PMTCTLPGM parameter) of the PARM statement is coded for the parameter specified here, the value returned by the program specified in that PMTCTLPGM parameter is compared to the values specified on the Controlling conditions (COND) parameter. If the parameter specified here is a list or qualified name, only the first list item or qualifier is compared.",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1
    },
    {
      "name": "COND",
      "description": "Controlling conditions",
      "help": "Controlling conditions (COND)\n\nSpecifies the condition against which the parameter specified on the Controlling keyword (CTL) parameter is tested. Up to 50 conditions can be specified.",
      "inputType": "group",
      "required": true,
      "groupKind": "elements",
      "children": [
        {
          "name": "COND_E1",
          "description": "Relational operator",
          "inputType": "dropdown",
          "required": true,
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*GT",
              "value": "*GT"
            },
            {
              "label": "*EQ",
              "value": "*EQ"
            },
            {
              "label": "*GE",
              "value": "*GE"
            },
            {
              "label": "*NL",
              "value": "*NL"
            },
            {
              "label": "*LT",
              "value": "*LT"
            },
            {
              "label": "*NE",
              "value": "*NE"
            },
            {
              "label": "*LE",
              "value": "*LE"
            },
            {
              "label": "*NG",
              "value": "*NG"
            },
            {
              "label": "*SPCFD",
              "value": "*SPCFD"
            },
            {
              "label": "*UNSPCFD",
              "value": "*UNSPCFD"
            }
          ]
        },
        {
          "name": "COND_E2",
          "description": "Controlling keyword value",
          "inputType": "text",
          "required": false
        }
      ],
      "positional": 2,
      "maxOccurrences": 50
    },
    {
      "name": "NBRTRUE",
      "description": "Number of true conditions",
      "help": "Number of true conditions (NBRTRUE)\n\nSpecifies the number of conditions specified on the Controlling conditions (COND) parameter that must be true if the parameter is prompted for.",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "singleValues": [
        "*ALL"
      ],
      "children": [
        {
          "name": "NBRTRUE_E1",
          "description": "Relational operator",
          "inputType": "dropdown",
          "required": false,
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*ALL",
              "value": "*ALL"
            },
            {
              "label": "*GT",
              "value": "*GT"
            },
            {
              "label": "*EQ",
              "value": "*EQ"
            },
            {
              "label": "*GE",
              "value": "*GE"
            },
            {
              "label": "*NL",
              "value": "*NL"
            },
            {
              "label": "*LT",
              "value": "*LT"
            },
            {
              "label": "*NE",
              "value": "*NE"
            },
            {
              "label": "*LE",
              "value": "*LE"
            },
            {
              "label": "*NG",
              "value": "*NG"
            }
          ],
          "defaultValue": "*ALL"
        },
        {
          "name": "NBRTRUE_E2",
          "description": "Number of true conditions",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          }
        }
      ]
    },
    {
      "name": "LGLREL",
      "description": "Logical relation",
      "help": "Logical relation (LGLREL)\n\nSpecifies, when PMTCTL statements are in a group, the logical relationship between this PMTCTL statement and the preceding PMTCTL statements in the group. This allows conditional prompting using more than one controlling parameter.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*AND",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*AND",
          "value": "*AND"
        },
        {
          "label": "*OR",
          "value": "*OR"
        }
      ]
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/pmtctl.htm",
    "version": "IBM i 7.4"
  }
}
