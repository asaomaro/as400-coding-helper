  "threadSafe": true,
  "environment": "すべての環境 (*ALL)",
  "examples": [
    {
      "code": "CHKOBJ   OBJ(LIB1/PROG1)  OBJTYPE(*PGM)"
    },
    {
      "code": "CHKOBJ   OBJ(SOURCE1)  OBJTYPE(*FILE)  MBR(MBR3)  AUT(*CHANGE)"
    },
    {
      "code": "CHKOBJ   OBJ(LIB1/PROG1)  OBJTYPE(*PGM)  AUT(*CHANGE)"
    },
    {
      "code": "CHKOBJ   OBJ(FILEA)  OBJTYPE(*FILE)  MBR(MBR1)  AUT(*USE)"
    },
    {
      "code": "CHKOBJ   OBJ(FILEA)  OBJTYPE(*FILE)  MBR(MBR1)  AUT(*ADD  *DLT)"
    }
  ],
