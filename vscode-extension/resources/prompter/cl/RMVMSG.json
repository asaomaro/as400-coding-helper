{
  "keyword": "RMVMSG",
  "description": "メッセージ除去（RMVMSG）",
  "help": "指定したメッセージ待ち行列から1つまたは複数のメッセージを除去します。",
  "parameters": [
    {
      "name": "PGMQ",
      "description": "呼出スタック項目メッセージ待行列",
      "help": "対象の呼び出しスタック項目メッセージ待ち行列。単一値 *ALLINACT（全非活動）/ *EXT（外部）も可。要素はネストのため平坦化。MSGQ と排他的に使う。",
      "inputType": "group",
      "required": false,
      "children": [
        {
          "name": "RELATION",
          "description": "関係",
          "help": "*SAME（その項目自身）/ *PRV（直前の項目）。",
          "inputType": "dropdown",
          "required": false,
          "defaultValue": "*SAME",
          "options": [
            { "label": "*SAME（その項目自身）", "value": "*SAME" },
            { "label": "*PRV（直前の項目）", "value": "*PRV" }
          ]
        },
        {
          "name": "CSEID",
          "description": "呼び出しスタック項目",
          "help": "OPMプログラム名/ILEプロシージャー名、または * 。",
          "inputType": "text",
          "required": false,
          "attributes": { "maxLength": 256 },
          "placeholder": "*"
        },
        {
          "name": "MODULE",
          "description": "モジュール",
          "help": "ILEモジュール名（修飾子）。既定 *NONE。",
          "inputType": "text",
          "required": false,
          "attributes": { "characterSet": "upper", "maxLength": 10 },
          "placeholder": "*NONE"
        },
        {
          "name": "PGM",
          "description": "バインド済みプログラム",
          "help": "バインド先プログラム名（修飾子）。既定 *NONE。",
          "inputType": "text",
          "required": false,
          "attributes": { "characterSet": "upper", "maxLength": 10 },
          "placeholder": "*NONE"
        }
      ]
    },
    {
      "name": "MSGQ",
      "description": "MSG待ち行列",
      "help": "メッセージを除去するメッセージ待ち行列を指定します。単一値: *PGMQ=PGMQ で指定した待ち行列。",
      "inputType": "group",
      "required": false,
      "children": [
        {
          "name": "LIB",
          "description": "ライブラリー",
          "help": "メッセージ待ち行列のライブラリー名を指定します。定義済み値: *LIBL、*CURLIB。",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": { "characterSet": "upper", "maxLength": 10 },
          "placeholder": "*LIBL"
        },
        {
          "name": "MSGQ",
          "description": "MSG待ち行列",
          "help": "メッセージ待ち行列名を指定します。",
          "inputType": "text",
          "required": false,
          "attributes": { "characterSet": "upper", "maxLength": 10 },
          "placeholder": "*PGMQ"
        }
      ]
    },
    {
      "name": "MSGKEY",
      "description": "メッセージ・キー",
      "help": "除去する特定メッセージのメッセージ・キー（文字値、通常はCL変数）を指定します。",
      "inputType": "text",
      "required": false,
      "placeholder": "&MSGKEY"
    },
    {
      "name": "CLEAR",
      "description": "消去",
      "help": "除去するメッセージの範囲を指定します。",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*BYKEY",
      "options": [
        { "label": "*BYKEY（キー指定）", "value": "*BYKEY" },
        { "label": "*ALL（すべて）", "value": "*ALL" },
        { "label": "*KEEPUNANS（未応答は残す）", "value": "*KEEPUNANS" },
        { "label": "*OLD（旧メッセージ）", "value": "*OLD" },
        { "label": "*NEW（新メッセージ）", "value": "*NEW" }
      ]
    },
    {
      "name": "RMVEXCP",
      "description": "未処理例外の除去",
      "help": "未処理例外を除去するかを指定します。*YES=除去、*NO=残す。",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*YES",
      "options": [
        { "label": "*YES（除去）", "value": "*YES" },
        { "label": "*NO（残す）", "value": "*NO" }
      ]
    },
    {
      "name": "RJTDFTRPY",
      "description": "省略時応答の拒否",
      "help": "省略時応答の拒否を許可するかを指定します。*NOALWRJT=許可しない、*ALWRJT=許可する。",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NOALWRJT",
      "options": [
        { "label": "*NOALWRJT（拒否不可）", "value": "*NOALWRJT" },
        { "label": "*ALWRJT（拒否可）", "value": "*ALWRJT" }
      ]
    }
  ]
}
