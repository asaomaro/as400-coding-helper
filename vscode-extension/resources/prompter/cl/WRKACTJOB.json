{
  "keyword": "WRKACTJOB",
  "description": "活動ジョブ処理（WRKACTJOB）",
  "help": "システムまたは指定サブシステム内のすべての活動ジョブの状況・統計を表示または印刷します。CPU/応答時間の限界や表示順序、自動再表示間隔を指定できます。",
  "parameters": [
    {
      "name": "OUTPUT",
      "description": "出力",
      "help": "出力を要求元ワークステーションに表示するか、ジョブのスプール出力で印刷するか。",
      "inputType": "dropdown",
      "required": false,
      "options": [
        { "label": "*（対話式は表示・非対話式は印刷）", "value": "*" },
        { "label": "*PRINT（印刷）", "value": "*PRINT" }
      ]
    },
    {
      "name": "RESET",
      "description": "状況統計リセット",
      "help": "活動ジョブ統計をリセットするか。*NO（リセットしない・測定間隔を延長）/ *YES（リセット）。",
      "inputType": "dropdown",
      "required": false,
      "options": [
        { "label": "*NO（リセットしない）", "value": "*NO" },
        { "label": "*YES（リセットする）", "value": "*YES" }
      ]
    },
    {
      "name": "SBS",
      "description": "サブシステム",
      "help": "活動ジョブを表示するサブシステム。単一値 *ALL（全サブシステム）、またはその他の値（最大25回）としてサブシステム名。",
      "inputType": "text",
      "required": false,
      "attributes": { "characterSet": "upper", "maxLength": 10 },
      "defaultValue": "*ALL",
      "placeholder": "*ALL",
      "maxOccurrences": 25
    },
    {
      "name": "CPUPCTLMT",
      "description": "CPUパーセント限界",
      "help": "画面に含めるためにジョブが必要とする最小処理時間パーセント。*NONE（制限なし）/ 0.1-99.9。",
      "inputType": "text",
      "required": false,
      "attributes": { "maxLength": 5 },
      "defaultValue": "*NONE",
      "placeholder": "*NONE"
    },
    {
      "name": "RSPLMT",
      "description": "応答時間限界",
      "help": "画面に含めるためにジョブが必要とする最小応答時間限界。*NONE（制限なし）/ 0.1-999.9。",
      "inputType": "text",
      "required": false,
      "attributes": { "maxLength": 5 },
      "defaultValue": "*NONE",
      "placeholder": "*NONE"
    },
    {
      "name": "SEQ",
      "description": "順序",
      "help": "活動ジョブの表示順序。",
      "inputType": "dropdown",
      "required": false,
      "options": [
        { "label": "*SBS（サブシステム）", "value": "*SBS" },
        { "label": "*AUXIO（補助記憶域入出力）", "value": "*AUXIO" },
        { "label": "*CPU（CPU時間）", "value": "*CPU" },
        { "label": "*CPUPCT（CPUパーセント）", "value": "*CPUPCT" },
        { "label": "*CURUSR（現行ユーザー）", "value": "*CURUSR" },
        { "label": "*FUNCTION（機能）", "value": "*FUNCTION" },
        { "label": "*INT（対話数）", "value": "*INT" },
        { "label": "*JOB（ジョブ名）", "value": "*JOB" },
        { "label": "*NUMBER（ジョブ番号）", "value": "*NUMBER" },
        { "label": "*POOL（プール）", "value": "*POOL" },
        { "label": "*PTY（優先順位）", "value": "*PTY" },
        { "label": "*RSP（応答時間）", "value": "*RSP" },
        { "label": "*STS（状況）", "value": "*STS" },
        { "label": "*THREADS（スレッド数）", "value": "*THREADS" },
        { "label": "*TMPSTG（一時記憶域）", "value": "*TMPSTG" },
        { "label": "*TYPE（タイプ）", "value": "*TYPE" },
        { "label": "*USER（ユーザー）", "value": "*USER" }
      ]
    },
    {
      "name": "JOB",
      "description": "ジョブ名",
      "help": "表示する活動ジョブの名前。*ALL（全活動ジョブ）/ *SYS（全システム・ジョブ）/ *SBS（全サブシステム・モニター）/ 総称名 / ジョブ名。",
      "inputType": "text",
      "required": false,
      "attributes": { "characterSet": "upper", "maxLength": 10 },
      "defaultValue": "*ALL",
      "placeholder": "*ALL"
    },
    {
      "name": "INTERVAL",
      "description": "自動再表示間隔",
      "help": "自動最新表示で待機する間隔（秒）。*PRV（前回値・既定300秒）/ 5-999。",
      "inputType": "text",
      "required": false,
      "attributes": { "characterSet": "upper", "maxLength": 4 },
      "defaultValue": "*PRV",
      "placeholder": "*PRV"
    }
  ]
}
