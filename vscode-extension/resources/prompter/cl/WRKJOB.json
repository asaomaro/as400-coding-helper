{
  "keyword": "WRKJOB",
  "description": "ジョブ処理（WRKJOB）",
  "help": "指定したユーザー・ジョブの状況・属性・スプール・ジョブ・ログ・呼び出しスタックなどの情報を表示または印刷します。",
  "parameters": [
    {
      "name": "JOB",
      "description": "ジョブ名",
      "help": "情報を処理するジョブ。単一値 *（このコマンドを実行したジョブ）、または「ジョブ名/ユーザー/番号」の修飾ジョブ名。",
      "inputType": "group",
      "required": false,
      "children": [
        {
          "name": "JOB",
          "description": "ジョブ名",
          "help": "表示するジョブの名前。修飾子を指定しない場合は全ジョブから単純名で検索されます。* でこのコマンドを実行したジョブ。",
          "inputType": "text",
          "required": false,
          "attributes": { "characterSet": "upper", "maxLength": 10 },
          "placeholder": "*"
        },
        {
          "name": "USER",
          "description": "ユーザー",
          "help": "ジョブの実行に使用されるユーザー・プロファイル名。",
          "inputType": "text",
          "required": false,
          "attributes": { "characterSet": "upper", "maxLength": 10 }
        },
        {
          "name": "NBR",
          "description": "番号",
          "help": "システムによって割り当てられたジョブ番号（000000-999999）。",
          "inputType": "text",
          "required": false,
          "attributes": { "numericOnly": true, "maxLength": 6 }
        }
      ]
    },
    {
      "name": "OUTPUT",
      "description": "出力",
      "help": "出力を要求元ワークステーションに表示するか、ジョブのスプール出力で印刷するか。",
      "inputType": "dropdown",
      "required": false,
      "options": [
        { "label": "*（対話式は表示・非対話式は印刷）", "value": "*" },
        { "label": "*PRINT（印刷）", "value": "*PRINT" }
      ]
    },
    {
      "name": "OPTION",
      "description": "オプション",
      "help": "処理する情報の種類。*SELECT（メニュー表示）/ *STSA / *DFNA / *RUNA / *SPLF / *JOBLOG / *PGMSTK / *JOBLCK / *LIBL / *OPNF / *FILOVR / *CMTCTL / *CMNSTS / *ACTGRP / *MUTEX / *THREAD / *MLBA / *ENVVAR / *ALL。",
      "inputType": "dropdown",
      "required": false,
      "options": [
        { "label": "*SELECT（メニュー表示）", "value": "*SELECT" },
        { "label": "*STSA（状況属性）", "value": "*STSA" },
        { "label": "*DFNA（定義属性）", "value": "*DFNA" },
        { "label": "*RUNA（実行属性）", "value": "*RUNA" },
        { "label": "*SPLF（スプール・ファイル）", "value": "*SPLF" },
        { "label": "*JOBLOG（ジョブ・ログ）", "value": "*JOBLOG" },
        { "label": "*PGMSTK（呼び出しスタック）", "value": "*PGMSTK" },
        { "label": "*JOBLCK（オブジェクト・ロック）", "value": "*JOBLCK" },
        { "label": "*LIBL（ライブラリー・リスト）", "value": "*LIBL" },
        { "label": "*OPNF（オープン・ファイル）", "value": "*OPNF" },
        { "label": "*FILOVR（ファイル一時変更）", "value": "*FILOVR" },
        { "label": "*CMTCTL（コミットメント制御）", "value": "*CMTCTL" },
        { "label": "*CMNSTS（通信状況）", "value": "*CMNSTS" },
        { "label": "*ACTGRP（活動化グループ）", "value": "*ACTGRP" },
        { "label": "*MUTEX（相互除外情報）", "value": "*MUTEX" },
        { "label": "*THREAD（スレッド情報）", "value": "*THREAD" },
        { "label": "*MLBA（媒体ライブラリー属性）", "value": "*MLBA" },
        { "label": "*ENVVAR（環境変数）", "value": "*ENVVAR" },
        { "label": "*ALL（すべて）", "value": "*ALL" }
      ]
    },
    {
      "name": "SLTTHD",
      "description": "組み込むスレッドID",
      "help": "情報を組み込むスレッドIDのリスト。単一値 *ALL / *SELECT、またはその他の値（最大20回）として *INITIAL / *CURRENT / スレッドID（文字値）。",
      "inputType": "text",
      "required": false,
      "attributes": { "characterSet": "upper", "maxLength": 16 },
      "defaultValue": "*ALL",
      "placeholder": "*ALL",
      "maxOccurrences": 20
    },
    {
      "name": "DUPJOBOPT",
      "description": "重複ジョブ・オプション",
      "help": "重複ジョブが見つかった時の処置。*SELECT（対話式は選択画面・他はメッセージ）/ *MSG（メッセージ）。",
      "inputType": "dropdown",
      "required": false,
      "options": [
        { "label": "*SELECT（選択画面またはメッセージ）", "value": "*SELECT" },
        { "label": "*MSG（メッセージ）", "value": "*MSG" }
      ]
    }
  ]
}
