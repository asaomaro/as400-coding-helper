{
  "keyword": "ADDPFM",
  "description": "物理ファイル・メンバー追加（ADDPFM）",
  "help": "既存の物理ファイルにメンバーを追加します。",
  "parameters": [
    {
      "name": "FILE",
      "description": "物理ファイル",
      "help": "メンバーを追加する物理ファイルを指定します。これは必須パラメーターです。",
      "inputType": "group",
      "required": true,
      "children": [
        {
          "name": "LIB",
          "description": "ライブラリー",
          "help": "物理ファイルのライブラリー名。定義済み値: *LIBL、*CURLIB。",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": { "characterSet": "upper", "maxLength": 10 },
          "placeholder": "*LIBL"
        },
        {
          "name": "FILE",
          "description": "物理ファイル",
          "help": "物理ファイル名を指定します。",
          "inputType": "text",
          "required": true,
          "attributes": { "characterSet": "upper", "maxLength": 10 },
          "placeholder": "MYFILE"
        }
      ]
    },
    {
      "name": "MBR",
      "description": "メンバー",
      "help": "追加するメンバー名を指定します。これは必須パラメーターです。",
      "inputType": "text",
      "required": true,
      "attributes": { "characterSet": "upper", "maxLength": 10 },
      "placeholder": "MYMBR"
    },
    {
      "name": "TEXT",
      "description": "テキスト'記述'",
      "help": "メンバーのテキスト記述（文字値）を指定します。定義済み値: *BLANK。",
      "inputType": "text",
      "required": false,
      "defaultValue": "*BLANK",
      "attributes": { "maxLength": 50 },
      "placeholder": "'メンバーの説明'"
    },
    {
      "name": "EXPDATE",
      "description": "メンバーの満了日",
      "help": "メンバーの満了日を指定します。定義済み値: *NONE=満了日なし。",
      "inputType": "text",
      "required": false,
      "defaultValue": "*NONE",
      "placeholder": "*NONE"
    },
    {
      "name": "SHARE",
      "description": "オープン・データ・パス共用",
      "help": "同一ジョブ内でオープン・データ・パスを共用するかを指定します。*NO=共用しない、*YES=共用する。",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "options": [
        { "label": "*NO（共用しない）", "value": "*NO" },
        { "label": "*YES（共用する）", "value": "*YES" }
      ]
    },
    {
      "name": "SRCTYPE",
      "description": "ソース仕様タイプ",
      "help": "ソース・メンバーのタイプ（単純名、例 RPGLE/CLP）を指定します。定義済み値: *NONE。",
      "inputType": "text",
      "required": false,
      "defaultValue": "*NONE",
      "attributes": { "characterSet": "upper", "maxLength": 10 },
      "placeholder": "RPGLE"
    }
  ]
}
