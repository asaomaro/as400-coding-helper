        "SELECT",
        "SPLNBR"
      ],
      "note": "SELECT に指定した値は SPLNBR に指定した値と相互に排他的です。"
    },
    {
      "kind": "exclusive",
      "parameters": [
        "SELECT",
        "JOBSYSNAME"
      ],
      "note": "SELECT に指定した値は JOBSYSNAME に指定した値と相互に排他的です。"
    },
    {
      "kind": "exclusive",
      "parameters": [
        "SELECT",
        "CRTDATE"
      ],
      "note": "SELECT に指定した値は CRTDATE に指定した値と相互に排他的です。"
    }
  ],
