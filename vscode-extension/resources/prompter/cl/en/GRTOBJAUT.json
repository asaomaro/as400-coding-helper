    {
      "name": "REFASPDEV",
      "description": "Reference ASP device",
      "help": "Reference ASP device (REFASPDEV)\n\nSpecifies the auxiliary storage pool (ASP) device name where the library that contains the reference object (REFOBJ parameter) is located. If the reference object's library resides in an ASP that is not part of the library name space associated with the job, this parameter must be specified to ensure the correct object is queried for authorities.\n\n指定できる特殊値: *, *SYSBAS",
      "inputType": "text",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "*",
      "basic": true
    },
    {
      "name": "REPLACE",
      "description": "Replace authority",
      "help": "Replace authority (REPLACE)\n\nSpecifies whether the authorities replace the user's current authorities.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
      ],
      "basic": true,
      "valueMap": {
        "*NO": "N",
        "*YES": "Y"
      }
    }
  ],
