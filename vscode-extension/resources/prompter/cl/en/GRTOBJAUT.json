    {
      "name": "ASPDEV",
      "description": "ASP device",
      "help": "ASP device (ASPDEV)\n\nSpecifies the auxiliary storage pool (ASP) device name where the library that contains the object (OBJ parameter) is located. If the object's library resides in an ASP that is not part of the library name space associated with the job, this parameter must be specified to ensure the correct object is used as the target of this command's operation.\n\n指定できる特殊値: *, *SYSBAS",
      "inputType": "text",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "*",
      "basic": true
    },
    {
      "name": "USER",
      "description": "Users",
      "help": "Users (USER)\n\nSpecifies one or more users to whom authority for the named object is to be given.\n\nThis is a required parameter unless either the Reference object (REFOBJ) parameter or Authorization list (AUTL) parameter is specified.\n\n指定できる特殊値: *PUBLIC",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 3,
      "maxOccurrences": 50,
      "placeholder": "*PUBLIC",
      "basic": true
    },
    {
      "name": "AUT",
      "description": "Authority",
      "help": "Authority (AUT)\n\nSpecifies the authority to be given to the users specified for the Users (USER) parameter.\n\nIf a value is specified for this parameter, you cannot specify a value for the AUTL, REFOBJ, or REFOBJTYPE parameters.\n\nSingle values\n\nNote: You can specify AUT(*AUTL) only when USER(*PUBLIC) is also specified.\n\nOther values (up to 10 repetitions)\n\nData authorities",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*CHANGE",
