{
  "keyword": "RMVJOBQE",
  "description": "Remove Job Queue Entry (RMVJOBQE)",
  "parameters": [
    {
      "name": "SBSD",
      "description": "Subsystem description",
      "help": "Subsystem description (SBSD)\n\nSpecifies the name and library of the subsystem description from which the job queue entry is removed.\n\nThis is a required parameter.\n\nQualifier 1: Subsystem description\n\nNote: The IBM-supplied object QSYSSBSD is not valid on this parameter.\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SBSD",
          "description": "Subsystem description",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "JOBQ",
      "description": "Job queue",
      "help": "Job queue entry job queue (JOBQ)\n\nSpecifies the name and library of the job queue that has its job queue entry removed from the subsystem description.\n\nThis is a required parameter.\n\nQualifier 1: Job queue\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "JOBQ_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "JOBQ",
          "description": "Job queue",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "RMVJOBQE SBSD(MYLIB/NIGHTRUN) JOBQ(MYLIB/BATCH2)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/rmvjobqe.htm",
    "version": "IBM i 7.4"
  }
