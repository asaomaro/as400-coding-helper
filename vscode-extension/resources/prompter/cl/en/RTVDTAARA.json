{
  "keyword": "RTVDTAARA",
  "description": "Retrieve Data Area (RTVDTAARA)",
  "parameters": [
    {
      "name": "DTAARA",
      "description": "Data area specification",
      "help": "Data area specification (DTAARA)\n\nSpecifies the name of the data area whose value is retrieved.\n\nThis is a required parameter.\n\nElement 1: Data area\n\nSingle values\n\nQualifier 1: Data area\n\nQualifier 2: Library\n\nElement 2: Substring specifications\n\nSingle values\n\nElement 1: Substring starting position\n\nElement 2: Substring length",
      "inputType": "group",
      "required": true,
      "groupKind": "elements",
      "children": [
        {
          "name": "DTAARA_E1",
          "description": "Data area",
          "inputType": "group",
          "required": false,
          "groupKind": "qualified",
          "singleValues": [
            "*LDA",
            "*GDA",
            "*PDA"
          ],
          "children": [
            {
              "name": "LIB",
              "description": "Library",
              "help": "指定できる特殊値: *LIBL, *CURLIB",
              "inputType": "text",
              "required": false,
              "defaultValue": "*LIBL",
              "attributes": {
                "characterSet": "upper",
                "maxLength": 10
              }
            },
            {
              "name": "DTAARA",
              "description": "Data area",
              "inputType": "text",
              "required": true,
              "attributes": {
                "characterSet": "upper",
                "maxLength": 10
              },
              "help": "指定できる特殊値: *LDA, *GDA, *PDA"
            }
          ]
        },
        {
          "name": "DTAARA_E2",
          "description": "Substring specifications",
          "inputType": "dropdown",
          "required": false,
          "defaultValue": "*ALL",
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*ALL",
              "value": "*ALL"
            }
          ]
        },
        {
          "name": "DTAARA_E1",
          "description": "Substring starting position",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          }
        },
        {
          "name": "DTAARA_DTAARA_E2",
          "description": "Substring length",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          }
        }
      ],
      "positional": 1,
      "basic": true
    },
    {
      "name": "RTNVAR",
      "description": "CL variable for returned value",
      "help": "CL variable for returned value (RTNVAR)\n\nSpecifies the name of the variable that receives the contents of the data area.\n\nNo type conversion is performed by the RTVDTAARA command:\n\nIf a retrieved character string is shorter than the length of the variable specified by the RTNVAR parameter, the value is padded on the right with blanks. The retrieved string length must be less than or equal to the variable length.\n\nWhen decimal data areas are retrieved, the decimals are aligned. The value of the integer portion of the data area must fit into the integer portions of the variable. Fractional data is truncated if the fraction contains more digits than the variable.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "positional": 2,
      "placeholder": "&RTNVAR",
      "basic": true
    }
  ],
  "examples": [
    {
      "code": "RTVDTAARA DTAARA(DA1) RTNVAR(&CLVAR1)"
    },
    {
      "code": "RTVDTAARA DTAARA(DA1 (2 1)) RTNVAR(&CLVAR1)"
    },
    {
      "code": "RTVDTAARA DTAARA(DA2) RTNVAR(&CLVAR2)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/rtvdtaara.htm",
    "version": "IBM i 7.4"
  }
}
