{
  "keyword": "CHGOBJOWN",
  "description": "Change Object Owner (CHGOBJOWN)",
  "parameters": [
    {
      "name": "OBJ",
      "description": "Object",
      "help": "Object (OBJ)\n\nSpecifies the object that is to be assigned to a new owner.\n\nThis is a required parameter.\n\nNote: A library name can be specified to ensure that the correct object changes ownership.\n\nQualifier 1: Object\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "OBJ",
          "description": "Object",
          "inputType": "text",
          "required": true,
