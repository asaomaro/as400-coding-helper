    {
      "name": "ASPDEV",
      "description": "ASP device",
      "help": "ASP device (ASPDEV)\n\nSpecifies the auxiliary storage pool (ASP) device name where the library that contains the object (OBJ parameter) is located. If the object's library resides in an ASP that is not part of the library name space associated with the job, this parameter must be specified to ensure the correct object is used as the target of this command's operation.\n\n指定できる特殊値: *, *SYSBAS",
      "inputType": "text",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "basic": true
    },
    {
      "name": "NEWOWN",
      "description": "New owner",
      "help": "New owner (NEWOWN)\n\nSpecifies the user profile of the new owner for the object. The user profile must exist when this command is run.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 3,
      "basic": true
    },
    {
      "name": "CUROWNAUT",
      "description": "Current owner authority",
      "help": "Current owner authority (CUROWNAUT)\n\nSpecifies whether the authorities for the current owner are revoked when ownership is changed.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*REVOKE",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
