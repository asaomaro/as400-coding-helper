              "relation": "EQ",
              "compareValue": "R"
            }
          ]
        }
      ]
    },
    {
      "name": "RMTNETID",
      "description": "Remote network identifier",
      "help": "Remote network identifier (RMTNETID)\n\nSpecifies the remote network identifier (ID) in which the remote location resides that is used to communicate with the target system.\n\nMore information on remote network IDs is in the APPC Programming book, SC41-5443.\n\n指定できる特殊値: *LOC, *NETATR, *NONE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*LOC",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 8
      },
      "placeholder": "*LOC",
      "promptControl": [
        {
          "controlParameter": "TYPE",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "R"
            }
          ]
        }
      ]
    },
    {
      "name": "TEXT",
      "description": "Text 'description'",
      "help": "Text 'description' (TEXT)\n\nSpecifies the text that briefly describes the object.\n\n指定できる特殊値: *BLANK",
      "inputType": "text",
      "required": false,
      "defaultValue": "*BLANK",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 50
      },
      "placeholder": "'データ域の説明'"
    },
    {
      "name": "AUT",
      "description": "Authority",
      "help": "Authority (AUT)\n\nSpecifies the authority you are giving to users who do not have specific authority for the object, who are not on an authorization list, and whose group profile or supplemental group profiles do not have specific authority for the object.\n\n指定できる特殊値: *LIBCRTAUT, *CHANGE, *ALL, *USE, *EXCLUDE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*LIBCRTAUT",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "*LIBCRTAUT"
    }
  ],
  "examples": [
    {
      "code": "CRTDTAARA DTAARA(TOTSALES) TYPE(*DEC) LEN(15 2) VALUE(0) TEXT('Total sales accumulator')"
    },
    {
      "code": "CRTDTAARA DTAARA(CUSTOMER) TYPE(*CHAR) LEN(148) TEXT('Customer name area')"
    },
    {
      "code": "CRTDTAARA DTAARA(SOURCE/SALES) TYPE(*DDM) RMTDTAARA(REMOTE/SALES) RMTLOCNAME(NEWYORK)"
    }
  ],
