    },
    {
      "name": "MODE",
      "description": "Mode",
      "help": "Mode (MODE)\n\nSpecifies the mode name that is used with the remote location name to communicate with the target system.\n\nMore information on mode names is in the APPC Programming book, SC41-5443.\n\n指定できる特殊値: *NETATR",
      "inputType": "text",
      "required": false,
      "defaultValue": "*NETATR",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 8
      },
      "placeholder": "*NETATR",
