{
  "keyword": "CLRJOBQ",
  "description": "Clear Job Queue (CLRJOBQ)",
  "parameters": [
    {
      "name": "JOBQ",
      "description": "Job queue",
      "help": "Job queue (JOBQ)\n\nSpecifies the job queue that is to be cleared of all waiting or held jobs.\n\nThis is a required parameter.\n\nQualifier 1: Job queue\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "JOBQ",
          "description": "Job queue",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "LOG",
      "description": "Job log",
      "help": "LOG (LOG)\n\nSpecifies whether to use the message logging values associated with a job for jobs removed from the job queue.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*JOB",
          "value": "*JOB"
        },
        {
          "label": "*NONE",
          "value": "*NONE"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "CLRJOBQ JOBQ(QBATCH)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/clrjobq.htm",
    "version": "IBM i 7.4"
  }
}
