{
  "keyword": "RMVMSGD",
  "description": "Remove Message Description (RMVMSGD)",
  "parameters": [
    {
      "name": "MSGID",
      "description": "Message identifier",
      "help": "Message identifier (MSGID)\n\nSpecifies the message identifier of the message to be removed from the message file.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1
    },
    {
      "name": "MSGF",
      "description": "Message file",
      "help": "Message file (MSGF)\n\nSpecifies the message file containing the message to be removed. Any message file overrides in effect for the job are ignored by this command; the file specified here is the one from which the message is removed.\n\nThis is a required parameter.\n\nQualifier 1: Message file\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "MSGF",
          "description": "Message file",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "RMVMSGD MSGID(UIN0115) MSGF(INV)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/rmvmsgd.htm",
    "version": "IBM i 7.4"
  }
}
