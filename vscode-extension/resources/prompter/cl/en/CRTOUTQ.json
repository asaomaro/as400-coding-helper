          "label": "*DTAAUT",
          "value": "*DTAAUT"
        }
      ]
    },
    {
      "name": "AUT",
      "description": "Authority",
      "help": "Authority (AUT)\n\nSpecifies the authority you are giving to users who do not have specific authority for the object, who are not on an authorization list, and whose group profile or supplemental group profiles do not have specific authority for the object.\n\n指定できる特殊値: *USE, *ALL, *CHANGE, *EXCLUDE, *LIBCRTAUT",
      "inputType": "text",
      "required": false,
      "defaultValue": "*USE",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      }
    }
