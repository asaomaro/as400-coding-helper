{
  "keyword": "HLDSPLF",
  "description": "Hold Spooled File (HLDSPLF)",
  "parameters": [
    {
      "name": "FILE",
      "description": "Spooled file",
      "help": "Spooled file (FILE)\n\nSpecifies the spooled file to hold.\n\nThis is a required parameter.\n\n指定できる特殊値: *SELECT",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1,
      "placeholder": "*SELECT",
      "basic": true,
      "objectKind": "file"
    },
    {
      "name": "JOB",
      "description": "Job name",
      "help": "Job name (JOB)\n\nSpecifies the job that created the file being held.\n\nSingle values\n\nQualifier 1: Job name\n\nQualifier 2: User\n\nQualifier 3: Number",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "JOB_Q3",
          "description": "Number",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          },
          "placeholder": "*"
        },
        {
          "name": "JOB_Q2",
          "description": "User",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "JOB",
          "description": "Job name",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "defaultValue": "*"
        }
      ],
      "positional": 2,
      "basic": true
    },
    {
      "name": "SPLNBR",
      "description": "Spooled file number",
      "help": "Spooled file number (SPLNBR)\n\nSpecifies the number of the spooled file that was created by the specified job.\n\n指定できる特殊値: *ONLY, *LAST, *ANY",
      "inputType": "text",
      "required": false,
      "defaultValue": "*ONLY",
      "attributes": {
        "characterSet": "upper",
        "minValue": 1,
        "maxValue": 999999,
        "numericOnly": true
      },
      "positional": 3,
      "basic": true,
      "valueMap": {
        "*ANY": "-2",
        "*LAST": "-1",
        "*ONLY": "0"
      }
    },
    {
      "name": "JOBSYSNAME",
      "description": "Job system name",
      "help": "Job system name (JOBSYSNAME)\n\nSpecifies the name of the system where the job that created the spooled file (JOB parameter) ran. This parameter is considered after the job name, user name, job number, spooled file name, and spooled file number parameter requirements have been met.\n\n指定できる特殊値: *ONLY, *CURRENT, *ANY",
      "inputType": "text",
      "required": false,
      "defaultValue": "*ONLY",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 8
      },
      "basic": true
    },
    {
      "name": "CRTDATE",
      "description": "Spooled file created",
      "help": "Spooled file created (CRTDATE)\n\nSpecifies the date and time the spooled file was created. This parameter is considered after the job name, user name, job number, spooled file name, spooled file number, and job system name parameter requirements have been met.\n\nSingle values\n\nElement 1: Creation date\n\nElement 2: Creation time",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "singleValues": [
        "*ONLY",
        "*LAST"
      ],
      "children": [
        {
          "name": "CRTDATE",
          "description": "Creation date",
          "inputType": "text",
          "required": false,
          "defaultValue": "*ONLY",
          "placeholder": "*ONLY"
        },
        {
          "name": "CRTTIME",
          "description": "Creation time",
          "inputType": "dropdown",
          "required": false,
          "defaultValue": "*ONLY",
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*ONLY",
              "value": "*ONLY"
            },
            {
              "label": "*LAST",
              "value": "*LAST"
            }
          ],
          "placeholder": "*ONLY"
        }
      ],
      "basic": true,
      "valueMap": {
        "*LAST": "999999",
        "*ONLY": "999998"
      }
    },
    {
      "name": "SELECT",
      "description": "Select files for",
      "help": "Select files for (SELECT)\n\nSpecifies which group of files are to be held. Positional values can be specified to select the files: the user that created the file, the device that the file is queued for, the form type specified, the user data tag associated with the file, or the auxiliary storage pool the file is in. Only files that meet each of the values are selected.\n\nElement 1: User\n\nElement 2: Print device\n\nElement 3: Form type\n\nElement 4: User data\n\nElement 5: ASP",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "USER",
          "description": "User",
          "help": "指定できる特殊値: *CURRENT, *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*CURRENT",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*CURRENT"
        },
        {
          "name": "DEV",
          "description": "Print device",
          "help": "指定できる特殊値: *ALL, *OUTQ",
          "inputType": "text",
          "required": false,
          "defaultValue": "*ALL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*ALL"
        },
        {
          "name": "FORMTYPE",
          "description": "Form type",
          "help": "指定できる特殊値: *ALL, *STD",
          "inputType": "text",
          "required": false,
          "defaultValue": "*ALL",
          "attributes": {
            "characterSet": "upper"
          },
          "placeholder": "*ALL"
        },
        {
          "name": "USRDTA",
          "description": "User data",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*ALL",
          "attributes": {
            "characterSet": "upper"
          },
          "placeholder": "*ALL"
        },
        {
          "name": "ASP",
          "description": "ASP",
          "help": "指定できる特殊値: *ALL, *ASPDEV",
          "inputType": "text",
          "required": false,
          "defaultValue": "*ALL",
          "attributes": {
            "characterSet": "upper"
          },
          "placeholder": "*ALL"
        }
      ],
      "basic": true
    },
    {
      "name": "ASPDEV",
      "description": "ASP device",
      "help": "ASP device (ASPDEV)\n\nSpecifies the auxiliary storage pool device name from which spooled files are to be selected. This parameter is only valid if the ASP number (ASP) element of the Select parameter is *ALL or *ASPDEV.\n\n指定できる特殊値: *, *SYSBAS, *CURASPGRP",
      "inputType": "text",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "*",
      "basic": true
    },
    {
      "name": "OPTION",
      "description": "When to hold file",
      "help": "When to hold file (OPTION)\n\nSpecifies which option to use when holding the spooled file.\n\nNote: Specifying an option when the file is not being written has no effect.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*IMMED",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*IMMED",
          "value": "*IMMED"
        },
        {
          "label": "*PAGEEND",
          "value": "*PAGEEND"
        }
      ],
      "basic": true
    }
  ],
  "examples": [
    {
      "code": "HLDSPLF FILE(SHIPITEMS) JOB(00009/JONES/ORDER)"
    },
    {
      "code": "HLDSPLF FILE(QPJOBLOG) OPTION(*PAGEEND)"
    },
    {
      "code": "HLDSPLF FILE(QPJOBLOG) OPTION(*IMMED)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/hldsplf.htm",
    "version": "IBM i 7.4"
  },
  "constraints": [
    {
      "kind": "exclusive",
      "parameters": [
        "SELECT",
        "JOB"
      ],
      "note": "SELECT に指定した値は JOB に指定した値と相互に排他的です。"
