{
  "keyword": "ADDBNDDIRE",
  "description": "Add Binding Directory Entry (ADDBNDDIRE)",
  "parameters": [
    {
      "name": "BNDDIR",
      "description": "Binding directory",
      "help": "Binding directory (BNDDIR)\n\nSpecifies the binding directory to which an entry is added.\n\nThis is a required parameter.\n\nQualifier 1: Binding directory\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "BNDDIR",
          "description": "Binding directory",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "OBJ",
      "description": "Object specifications",
      "help": "Object specifications (OBJ)\n\nSpecifies one or more object names to be added to the binding directory.\n\nThis is a required parameter.\n\nYou can specify 50 values for this parameter.\n\nYou can control the activation of each service program. You can specify whether the referenced service program is activated at the same time as the program or service program being created from the binding directory, or is deferred until a procedure exported from the referenced service program is called. Deferring activation may improve your application's performance.\n\nElement 1: Object\n\nQualifier 1: Object\n\nQualifier 2: Library\n\nElement 2: Object type\n\nElement 3: Activation",
      "inputType": "group",
      "required": true,
      "groupKind": "elements",
      "children": [
        {
          "name": "OBJ_E1",
          "description": "Object",
          "inputType": "group",
          "required": false,
          "groupKind": "qualified",
          "children": [
            {
              "name": "OBJ_LIB",
              "description": "Library",
              "help": "指定できる特殊値: *LIBL",
              "inputType": "text",
              "required": false,
              "defaultValue": "*LIBL",
              "attributes": {
                "characterSet": "upper",
                "maxLength": 10
              }
            },
            {
              "name": "OBJ",
              "description": "Object",
              "help": "指定できる特殊値: *ALL",
              "inputType": "text",
              "required": true,
              "attributes": {
                "characterSet": "upper",
                "maxLength": 10
              }
            }
          ]
        },
        {
          "name": "OBJ_E2",
          "description": "Object type",
          "inputType": "dropdown",
          "required": false,
          "defaultValue": "*SRVPGM",
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*SRVPGM",
              "value": "*SRVPGM"
            },
            {
              "label": "*MODULE",
              "value": "*MODULE"
            }
          ]
        },
        {
          "name": "OBJ_E3",
          "description": "Activation",
          "inputType": "dropdown",
          "required": false,
          "defaultValue": "*IMMED",
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*IMMED",
              "value": "*IMMED"
            },
            {
              "label": "*DEFER",
              "value": "*DEFER"
            }
          ]
        }
      ],
      "positional": 2,
      "maxOccurrences": 50
    },
    {
      "name": "POSITION",
      "description": "Position specifications",
      "help": "Position specifications (POSITION)\n\nSpecifies the position in the binding directory where the list of objects is added.\n\nSingle values\n\nElement 1: Object position\n\nElement 2: Object\n\nQualifier 1: Object\n\nQualifier 2: Library\n\nElement 3: Object type",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "singleValues": [
        "*LAST",
        "*FIRST"
      ],
      "children": [
        {
          "name": "POSITION_E1",
          "description": "Object position",
          "inputType": "dropdown",
          "required": false,
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*LAST",
              "value": "*LAST"
            },
            {
              "label": "*FIRST",
              "value": "*FIRST"
            },
            {
              "label": "*AFTER",
              "value": "*AFTER"
            },
            {
              "label": "*BEFORE",
              "value": "*BEFORE"
            },
            {
              "label": "*REPLACE",
              "value": "*REPLACE"
            }
          ],
          "defaultValue": "*LAST"
        },
        {
          "name": "POSITION_E2",
          "description": "Object",
          "inputType": "group",
          "required": false,
          "groupKind": "qualified",
          "children": [
            {
              "name": "POSITION_LIB",
              "description": "Library",
              "help": "指定できる特殊値: *LIBL",
              "inputType": "text",
              "required": false,
              "defaultValue": "*LIBL",
              "attributes": {
                "characterSet": "upper",
                "maxLength": 10
              }
            },
            {
              "name": "POSITION",
              "description": "Object",
              "inputType": "text",
              "required": false,
              "attributes": {
                "characterSet": "upper",
                "maxLength": 10
              }
            }
          ]
        },
        {
          "name": "POSITION_E3",
          "description": "Object type",
          "inputType": "dropdown",
          "required": false,
          "defaultValue": "*SRVPGM",
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*SRVPGM",
              "value": "*SRVPGM"
            },
            {
              "label": "*MODULE",
              "value": "*MODULE"
            }
          ]
        }
      ],
      "positional": 3
    }
  ],
  "examples": [
    {
      "code": "ADDBNDDIRE BNDDIR(TESTBNDDIR) OBJ((TESTOBJ)) POSITION(*LAST)"
    },
    {
      "code": "ADDBNDDIRE BNDDIR(TESTBNDDIR) OBJ((TESTLIB/TESTOBJ *MODULE)) POSITION(*FIRST)"
    },
    {
      "code": "ADDBNDDIRE BNDDIR(TESTBNDDIR) OBJ((TESTLIB/TESTOBJ *MODULE) (TESTOBJ2)) POSITION(*FIRST)"
    },
    {
      "code": "ADDBNDDIRE BNDDIR(TESTBNDDIR) OBJ((TESTLIB/TESTOBJ *MODULE) (TESTOBJ2)) POSITION(*BEFORE *LIBL/TESTMOD *MODULE)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/addbnddire.htm",
    "version": "IBM i 7.4"
  }
}
