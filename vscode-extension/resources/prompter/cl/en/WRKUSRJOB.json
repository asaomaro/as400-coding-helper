{
  "keyword": "WRKUSRJOB",
  "description": "Work with User Jobs (WRKUSRJOB)",
  "parameters": [
    {
      "name": "USER",
      "description": "User whose jobs to display",
      "help": "User whose jobs to display (USER)\n\nThis parameter allows you to work with user jobs defined by the user profile which initiated the job. User jobs include interactive jobs, submitted batch jobs, communications-evoked batch jobs, MRT batch jobs, and autostart jobs. User jobs do not include system jobs, subsystem monitor jobs, spooling readers, or spooling writers.\n\n指定できる特殊値: *, *ALL",
      "inputType": "text",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1,
      "basic": true
    },
    {
      "name": "STATUS",
      "description": "Status of user jobs",
      "help": "Status of user jobs (STATUS)\n\nSpecifies the status of the user jobs being worked with.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*ALL",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*ALL",
          "value": "*ALL"
        },
        {
          "label": "*ACTIVE",
          "value": "*ACTIVE"
        },
        {
          "label": "*JOBQ",
          "value": "*JOBQ"
        },
        {
          "label": "*OUTQ",
          "value": "*OUTQ"
        }
      ],
      "positional": 2,
      "basic": true
    },
    {
      "name": "OUTPUT",
      "description": "Output",
      "help": "Output (OUTPUT)\n\nSpecifies whether the output from the command is displayed at the requesting work station or printed with the job's spooled output.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*",
          "value": "*"
        },
        {
          "label": "*PRINT",
          "value": "*PRINT"
        }
      ],
      "positional": 3,
      "basic": true
    },
    {
      "name": "JOBTYPE",
      "description": "Job type",
      "help": "Job type (JOBTYPE)\n\nSpecifies the type of the user jobs shown.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*ALL",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*ALL",
          "value": "*ALL"
        },
        {
          "label": "*INTERACT",
          "value": "*INTERACT"
        },
        {
          "label": "*BATCH",
          "value": "*BATCH"
        }
      ],
      "basic": true
    },
    {
      "name": "ASTLVL",
      "description": "Assistance level",
      "help": "Assistance level (ASTLVL)\n\nSpecifies which user interface to use.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*PRV",
      "attributes": {
        "restricted": true,
        "characterSet": "upper",
        "maxLength": 10
      },
      "options": [
        {
          "label": "*PRV",
          "value": "*PRV"
        },
        {
          "label": "*USRPRF",
          "value": "*USRPRF"
        },
        {
          "label": "*BASIC",
          "value": "*BASIC"
        },
        {
          "label": "*INTERMED",
          "value": "*INTERMED"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "WRKUSRJOB USER(PGMR12)"
    },
    {
      "code": "WRKUSRJOB USER(*ALL) STATUS(*JOBQ)"
    },
    {
      "code": "WRKUSRJOB USER(*ALL) STATUS(*ACTIVE) JOBTYPE(*INTERACT) ASTLVL(*BASIC)"
    }
  ],
