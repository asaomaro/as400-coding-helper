{
  "keyword": "WRKACTJOB",
  "description": "Work with Active Jobs (WRKACTJOB)",
  "parameters": [
    {
      "name": "OUTPUT",
      "description": "Output",
      "help": "Output (OUTPUT)\n\nSpecifies whether the output from the command is displayed at the requesting work station or printed with the job's spooled output.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*",
          "value": "*"
        },
        {
          "label": "*PRINT",
          "value": "*PRINT"
        }
      ],
      "positional": 1,
      "basic": true
    },
    {
      "name": "RESET",
      "description": "Reset status statistics",
      "help": "Reset status statistics (RESET)\n\nSpecifies whether the active job statistics are reset.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
      ],
      "positional": 2
    },
    {
      "name": "SBS",
      "description": "Subsystem",
      "help": "Subsystem (SBS)\n\nSpecifies the names of the subsystems (or all subsystems) whose active jobs are displayed.\n\nSingle values\n\nOther values (up to 25 repetitions)\n\n指定できる特殊値: *ALL",
      "inputType": "text",
      "required": false,
      "defaultValue": "*ALL",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "maxOccurrences": 25,
      "placeholder": "*ALL"
    },
    {
      "name": "CPUPCTLMT",
      "description": "CPU percent limit",
      "help": "CPU percent limit (CPUPCTLMT)\n\nSpecifies the minimum processing time percent value that a job must have before it is included on the display.\n\n指定できる特殊値: *NONE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*NONE",
      "attributes": {
        "characterSet": "upper"
      },
      "placeholder": "*NONE"
    },
    {
      "name": "RSPLMT",
      "description": "Response time limit",
      "help": "Response time limit (RSPLMT)\n\nSpecifies the minimum response time limit that a job must have before it is included on the display.\n\n指定できる特殊値: *NONE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*NONE",
      "attributes": {
        "characterSet": "upper"
      },
      "placeholder": "*NONE"
    },
    {
      "name": "SEQ",
