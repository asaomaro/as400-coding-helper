    {
      "name": "JOB",
      "description": "Job name",
      "help": "Job name (JOB)\n\nSpecifies the name of the job or jobs that created the spooled files to be selected.\n\nNote: This parameter is allowed only if *ALL is specified for the user name element of the SELECT parameter.\n\nSingle values\n\nQualifier 1: Select jobs\n\nQualifier 2: User\n\nQualifier 3: Number",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "singleValues": [
        "*ALL"
      ],
      "children": [
        {
          "name": "JOB_Q3",
          "description": "Number",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*ALL",
          "attributes": {
