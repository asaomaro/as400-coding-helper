{
  "keyword": "WRKSPLF",
  "description": "Work with Spooled Files (WRKSPLF)",
  "parameters": [
    {
      "name": "SELECT",
      "description": "Select files for",
      "help": "Select files for (SELECT)\n\nSpecifies which group of files is selected to be displayed. Positional values can be specified to select the files: the user that created the file, the device that the file is queued for, the form type specified, the user data tag associated with the file, the auxiliary storage pool the file is in, or the spooled file name. Only files that meet each of the values are selected.\n\nElement 1: User\n\nElement 2: Print device\n\nElement 3: Form type\n\nElement 4: User data\n\nElement 5: ASP\n\nElement 6: Spooled file",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "USER",
          "description": "User",
          "help": "指定できる特殊値: *CURRENT, *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*CURRENT",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*CURRENT"
        },
        {
