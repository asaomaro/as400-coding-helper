              "label": "*BEGIN",
              "value": "*BEGIN"
            },
            {
              "label": "*CURRENT",
              "value": "*CURRENT"
            }
          ]
        },
        {
          "name": "PERIOD_PERIOD_E2",
          "description": "End time and date",
          "inputType": "text",
          "required": false
        },
