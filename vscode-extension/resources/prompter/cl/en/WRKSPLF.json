          },
          "placeholder": "*ALL"
        },
        {
          "name": "USRDTA",
          "description": "User data",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*ALL",
          "attributes": {
            "characterSet": "upper"
          },
