        {
          "label": "*BASIC",
          "value": "*BASIC"
        },
        {
          "label": "*INTERMED",
          "value": "*INTERMED"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "WRKSPLF SELECT(*ALL *ALL *ALL *ALL *ALL *ALL) DSPFMT(*NORMAL)"
    },
    {
      "code": "WRKSPLF SELECT(CASMITH *ALL *ALL MEMO *ALL *ALL)"
    },
    {
      "code": "WRKSPLF SELECT(*ALL *ALL *ALL '*SAV*' *ALL *ALL)"
    },
    {
      "code": "WRKSPLF SELECT(*ALL) PERIOD(('11:30:00' '01/12/2005') ('20:00:00' '01/12/2005'))"
    }
  ],
