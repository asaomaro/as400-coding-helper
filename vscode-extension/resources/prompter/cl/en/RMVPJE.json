{
  "keyword": "RMVPJE",
  "description": "Remove Prestart Job Entry (RMVPJE)",
  "parameters": [
    {
      "name": "SBSD",
      "description": "Subsystem description",
      "help": "Subsystem description (SBSD)\n\nSpecifies the name and library of the subsystem description that contains the prestart job entry that is removed.\n\nThis is a required parameter.\n\nQualifier 1: Subsystem description\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SBSD",
          "description": "Subsystem description",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "PGM",
      "description": "Program",
      "help": "Program (PGM)\n\nSpecifies the name and library of the program for the prestart job entry that is removed. Two entries with the same program name can exist in a single subsystem description but they must have different library names.\n\nThis is a required parameter.\n\nQualifier 1: Program\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "PGM_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "PGM",
          "description": "Program",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "RMVPJE SBSD(QGPL/PJE) PGM(QGPL/PGM1)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/rmvpje.htm",
    "version": "IBM i 7.4"
