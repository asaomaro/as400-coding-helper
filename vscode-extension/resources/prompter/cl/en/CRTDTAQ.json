        {
          "label": "*YES",
          "value": "*YES"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "TYPE",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "NE",
              "compareValue": "R"
            }
          ]
        }
      ],
      "valueMap": {
        "*NO": "N",
        "*YES": "Y"
      }
    },
    {
      "name": "SIZE",
      "description": "Queue size",
      "help": "Queue size (SIZE)\n\nSpecifies the amount of storage allocated for the data queue. Parameter elements consist of the maximum number of entries and the initial number of entries for the data queue.\n\nNote: This parameter is valid only when TYPE(*STD) is specified.\n\nElement 1: Maximum number of entries\n\nOne of the following is used to specify the maximum number of entries that can be added to a data queue.\n\nElement 2: Initial number of entries\n\nSpecifies the amount of storage that will initially be allocated to the data queue. The queue will be created to hold the initial number of entries of the maximum entry length.",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "SIZE_E1",
          "description": "Maximum number of entries",
          "help": "指定できる特殊値: *MAX16MB, *MAX2GB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*MAX16MB",
          "attributes": {
            "characterSet": "upper"
          }
        },
        {
          "name": "SIZE_E2",
          "description": "Initial number of entries",
          "inputType": "number",
          "required": false,
          "defaultValue": "16",
          "attributes": {
            "numericOnly": true
          }
        }
      ],
      "promptControl": [
        {
          "controlParameter": "TYPE",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "NE",
              "compareValue": "R"
            }
          ]
        }
      ],
      "valueMap": {
        "*MAX16MB": "-1",
        "*MAX2GB": "-2"
      }
    },
    {
      "name": "AUTORCL",
      "description": "Automatic reclaim",
      "help": "Automatic reclaim (AUTORCL)\n\nSpecifies whether the storage allocated for the data queue is automatically reclaimed (released) when the data queue is empty.\n\nNote: This parameter is valid only when TYPE(*STD) is specified.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
