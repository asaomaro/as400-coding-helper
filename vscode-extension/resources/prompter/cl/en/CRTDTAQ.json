    {
      "name": "SENDERID",
      "description": "Include sender ID",
      "help": "Include sender ID (SENDERID)\n\nSpecifies a sender ID to be attached to each message sent to the Data Queue. The ID contains the job name and the sender's current user profile.\n\nNote: This parameter is valid only when TYPE(*STD) is specified.",
      "inputType": "dropdown",
      "required": false,
