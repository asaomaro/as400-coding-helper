              "compareValue": "R"
            }
          ]
        }
      ],
      "valueMap": {
        "*NO": "0",
        "*YES": "1"
      }
    },
    {
      "name": "RMTDTAQ",
      "description": "Remote data queue",
      "help": "Remote data queue (RMTDTAQ)\n\nSpecifies the remote data queue on the target system. The data queue does not need to exist when the DDM data queue is created.\n\nQualifier 1: Remote data queue\n\nQualifier 2: Library",
