        }
      ],
      "positional": 1
    },
    {
      "name": "TYPE",
      "description": "Type",
      "help": "Type (TYPE)\n\nSpecifies the type of data queue to be created. A standard data queue, a distributed data management (DDM) data queue, or a display data queue can be created.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*STD",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*STD",
          "value": "*STD"
        },
        {
          "label": "*DSP",
          "value": "*DSP"
        },
        {
          "label": "*DDM",
          "value": "*DDM"
        }
      ],
      "valueMap": {
        "*DDM": "R",
        "*DSP": "D",
        "*STD": "S"
      }
    },
    {
      "name": "MAXLEN",
      "description": "Maximum entry length",
      "help": "Maximum entry length (MAXLEN)\n\nSpecifies the maximum length of the entry that is sent to the data queue.\n\nNotes:",
      "inputType": "number",
