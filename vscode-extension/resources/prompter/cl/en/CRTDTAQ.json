    {
      "name": "RMTLOCNAME",
      "description": "Remote location",
      "help": "Remote location (RMTLOCNAME)\n\nSpecifies the name of the remote location that is used with this object.\n\nNote: Multiple DDM data queues can use the same remote location for the target system. The remote locations used must point to systems that are at a release of i5/OS that supports remote data queues.\n\nMore information on remote locations is in the APPC Programming book, SC41-5443.\n\n指定できる特殊値: *RDB",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 8
      },
      "promptControl": [
        {
          "controlParameter": "TYPE",
          "countRelation": "EQ",
