{
  "keyword": "CRTDTAQ",
  "description": "Create Data Queue (CRTDTAQ)",
  "parameters": [
    {
      "name": "DTAQ",
      "description": "Data queue",
      "help": "Data queue (DTAQ)\n\nSpecifies the data queue to be created.\n\nThis is a required parameter.\n\nQualifier 1: Data queue\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *CURLIB",
