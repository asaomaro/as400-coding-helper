      "description": "Key length",
      "help": "Key length (KEYLEN)\n\nSpecifies the number of characters in the key.\n\nNote: This parameter is valid only when SEQ(*KEYED) and TYPE(*STD) are specified.",
      "inputType": "number",
      "required": false,
      "attributes": {
