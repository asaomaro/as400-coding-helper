{
  "keyword": "WRKPGM",
  "description": "Work with Programs (WRKPGM)",
  "parameters": [
    {
      "name": "PGM",
      "description": "Program",
      "help": "Program (PGM)\n\nSpecifies the programs to be shown.\n\nThis is a required parameter.\n\nQualifier 1: Program\n\nQualifier 2: Library\n\nAlthough the following Qxxx libraries are provided by IBM, they typically contain user data that changes frequently. Therefore, these libraries are considered user libraries and are also searched:",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALLUSR, *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "PGM",
          "description": "Program",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "PGMATR",
      "description": "Program attribute",
      "help": "Program attribute (PGMATR)\n\nSpecifies whether only programs with a specific program attribute are shown.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*ALL",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*ALL",
          "value": "*ALL"
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "WRKPGM PGM(MYLIB/*ALL) PGMATR(CLP)"
    },
    {
      "code": "WRKPGM PGM(AB*)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/wrkpgm.htm",
    "version": "IBM i 7.4"
  }
}
