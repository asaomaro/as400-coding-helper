{
  "keyword": "DCL",
  "description": "Declare CL Variable (DCL)",
  "parameters": [
    {
      "name": "VAR",
      "description": "CL variable name",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1,
      "placeholder": "&VAR",
      "basic": true
    },
    {
      "name": "TYPE",
      "description": "Type",
      "inputType": "dropdown",
      "required": true,
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*DEC",
          "value": "*DEC"
        },
        {
          "label": "*CHAR",
          "value": "*CHAR"
        },
        {
          "label": "*LGL",
          "value": "*LGL"
        },
        {
          "label": "*INT",
          "value": "*INT"
        },
        {
          "label": "*UINT",
          "value": "*UINT"
        },
        {
          "label": "*PTR",
          "value": "*PTR"
        }
      ],
      "positional": 2,
      "basic": true
    },
    {
      "name": "STG",
      "description": "Storage",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*AUTO",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*AUTO",
          "value": "*AUTO"
        },
        {
          "label": "*BASED",
          "value": "*BASED"
        },
        {
          "label": "*DEFINED",
          "value": "*DEFINED"
        }
      ],
      "basic": true
    },
    {
      "name": "LEN",
      "description": "Length of variable",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "LENGTH",
          "description": "Length",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          },
          "placeholder": "10"
        },
        {
          "name": "DEC",
          "description": "Decimal positions",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          },
          "placeholder": "0"
        }
      ],
      "positional": 3
    },
    {
      "name": "VALUE",
      "description": "Initial value",
      "inputType": "text",
      "required": false,
      "positional": 4,
      "placeholder": "' '"
    },
    {
      "name": "BASPTR",
      "description": "Basing pointer variable",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "&PTR"
    },
    {
      "name": "DEFVAR",
      "description": "Defined on variable",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "DEFVAR_VAR",
          "description": "CL variable name",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "&BASE"
        },
        {
          "name": "POS",
          "description": "Position",
          "inputType": "number",
          "required": false,
          "defaultValue": "1",
          "attributes": {
            "numericOnly": true
          },
          "placeholder": "1"
        }
      ]
    },
    {
      "name": "ADDRESS",
      "description": "Address",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "singleValues": [
        "*NULL"
      ],
      "children": [
        {
          "name": "ADDRESS_VAR",
          "description": "CL variable name",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*NULL"
        },
        {
          "name": "OFFSET",
          "description": "Offset",
          "inputType": "number",
          "required": false,
          "defaultValue": "0",
          "attributes": {
            "numericOnly": true
          },
          "placeholder": "0"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "DCL &ABLE *DEC LEN(5 2)"
    },
    {
      "code": "DCL &SWITCH *LGL"
    },
    {
      "code": "DCL &FILNAM *CHAR VALUE(FILEA)"
    },
    {
      "code": "DCL &QUALOBJ *CHAR LEN(20) DCL &OBJ *CHAR LEN(10) STG(*DEFINED) DEFVAR(&QUALOBJ 1) DCL &LIB *CHAR LEN(10) STG(*DEFINED) DEFVAR(&QUALOBJ 11)"
    },
    {
      "code": "DCL &CHAR *CHAR LEN(10) DCL &PTR *PTR ADDRESS(&CHAR)"
    },
    {
      "code": "DCL &PTR *PTR DCL &CHAR *CHAR LEN(10) STG(*BASED) BASPTR(&PTR)"
    },
    {
      "code": "DCL &CHAR *CHAR LEN(48) DCL &PTR *PTR STG(*DEFINED) DEFVAR(&CHAR 17)"
    },
    {
      "code": "DCL &PAYREC *PTR STG(*AUTO) ADDRESS(*NULL)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/dcl.htm",
    "version": "IBM i 7.4"
  }
}
