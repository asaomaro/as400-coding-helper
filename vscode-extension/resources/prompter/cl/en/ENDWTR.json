{
  "keyword": "ENDWTR",
  "description": "End Writer (ENDWTR)",
  "parameters": [
    {
      "name": "WTR",
      "description": "Writer",
      "help": "Writer (WTR)\n\nSpecifies the spooling writer being ended. The writer's output device will then be available to the system.\n\nThis is a required parameter.\n\n指定できる特殊値: *ALL, *PRT, *RMT, *SYSVAL",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1
    },
    {
      "name": "OPTION",
      "description": "When to end writer",
      "help": "When to end writer (OPTION)\n\nSpecifies when the writer should stop processing.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*CNTRLD",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*CNTRLD",
          "value": "*CNTRLD"
        },
        {
          "label": "*IMMED",
          "value": "*IMMED"
        },
        {
          "label": "*PAGEEND",
          "value": "*PAGEEND"
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "ENDWTR WTR(PRINTER) OPTION(*CNTRLD)"
    },
    {
      "code": "ENDWTR WTR(*PRT) OPTION(*IMMED)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/endwtr.htm",
    "version": "IBM i 7.4"
  }
}
