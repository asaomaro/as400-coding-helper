{
  "keyword": "SNDUSRMSG",
  "description": "Send User Message (SNDUSRMSG)",
  "parameters": [
    {
      "name": "MSG",
      "description": "Message text, or",
      "inputType": "text",
      "required": false,
      "positional": 1,
      "placeholder": "'メッセージ・テキスト'",
      "basic": true
    },
    {
      "name": "MSGID",
      "description": "Message identifier",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "CPF0000",
      "basic": true
    },
    {
      "name": "MSGF",
      "description": "Message file",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*LIBL"
        },
        {
          "name": "MSGF",
          "description": "Message file",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "QCPFMSG"
        }
      ],
      "basic": true
    },
    {
      "name": "MSGDTA",
      "description": "Message data field values",
      "inputType": "text",
      "required": false,
      "placeholder": "&MSGDTA",
      "basic": true
    },
    {
      "name": "VALUES",
      "description": "Valid reply values",
      "help": "指定できる特殊値: *NONE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*NONE",
      "attributes": {
        "characterSet": "upper"
      },
      "maxOccurrences": 20,
      "placeholder": "*NONE",
      "basic": true
    },
    {
      "name": "DFT",
      "description": "Default reply value",
      "help": "指定できる特殊値: *MSGDFT",
      "inputType": "text",
      "required": false,
      "defaultValue": "*MSGDFT",
      "attributes": {
        "characterSet": "upper"
      },
      "placeholder": "*MSGDFT",
      "basic": true
    },
    {
      "name": "MSGTYPE",
      "description": "Message type",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*INQ",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*INQ",
          "value": "*INQ"
        },
        {
          "label": "*INFO",
          "value": "*INFO"
        }
      ],
      "basic": true
    },
    {
      "name": "TOMSGQ",
      "description": "To message queue",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "singleValues": [
        "*EXT",
        "*SYSOPR"
      ],
      "children": [
        {
          "name": "TOMSGQ_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*LIBL"
        },
        {
          "name": "TOMSGQ",
          "description": "To message queue",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "defaultValue": "*",
          "placeholder": "*SYSOPR"
        }
      ],
      "basic": true
    },
    {
      "name": "TOUSR",
      "description": "To user profile",
      "help": "指定できる特殊値: *SYSOPR, *REQUESTER",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "*REQUESTER",
      "basic": true
    },
    {
      "name": "MSGRPY",
      "description": "CL var for message reply",
      "inputType": "text",
      "required": false,
      "placeholder": "&MSGRPY",
      "basic": true
    },
    {
      "name": "TRNTBL",
      "description": "Translate table",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "singleValues": [
        "*NONE"
      ],
      "children": [
        {
          "name": "TRNTBL_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*LIBL"
        },
        {
          "name": "TRNTBL",
          "description": "Translate table",
          "inputType": "text",
          "required": false,
          "defaultValue": "QSYSTRNTBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*NONE"
        }
      ],
      "basic": true
    },
    {
      "name": "CCSID",
      "description": "Coded character set ID",
      "help": "指定できる特殊値: *HEX, *JOB",
      "inputType": "text",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper"
      },
      "placeholder": "*JOB"
    }
  ],
  "examples": [
    {
      "code": "SNDUSRMSG MSG('Data verified. Update master files (Y,N)?') TOMSGQ(*) VALUES(Y N) DFT(N) MSGRPY(&REPLY)"
    },
    {
      "code": "SNDUSRMSG MSG('Enter any response when ready to continue.') TOMSGQ(WS01)"
    },
    {
      "code": "SNDUSRMSG MSGID(USR0150) TOUSR(FRED) MSGF(QGPL/USRMSGF) MSGDTA(&ACCTNO) MSGTYPE(*INFO)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/sndusrmsg.htm",
    "version": "IBM i 7.4"
  }
}
