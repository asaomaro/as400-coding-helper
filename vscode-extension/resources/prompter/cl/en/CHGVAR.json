{
  "keyword": "CHGVAR",
  "description": "Change Variable (CHGVAR)",
  "parameters": [
    {
      "name": "VAR",
      "description": "CL variable name",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1,
      "placeholder": "&VAR",
      "basic": true
    },
    {
      "name": "VALUE",
      "description": "New value",
      "inputType": "text",
      "required": true,
      "positional": 2,
      "placeholder": "&VAR + 1",
      "basic": true
    }
  ],
  "examples": [
    {
      "code": "CHGVAR VAR(&B) VALUE(&A)"
    },
    {
      "code": "CHGVAR VAR(&A) VALUE(&B)"
    },
    {
      "code": "CHGVAR &A &B"
    },
    {
      "code": "CHGVAR &Y (&Y + 1)"
    },
    {
      "code": "CHGVAR &X (&Y *OR &Z)"
    },
    {
      "code": "CHGVAR &A %SWITCH(10XXXX10)"
    },
    {
      "code": "CHGVAR VAR(&A) VALUE(AB *CAT CD) CHGVAR &A ('AB' *CAT 'CD')"
    },
    {
      "code": "CHGVAR &VAR1 &VAR2"
    },
    {
      "code": "CHGVAR &VAR1 '12'"
    },
    {
      "code": "CHGVAR VAR(%SUBSTRING(&A 4 3)) VALUE(REP) or CHGVAR VAR(%SST(&A 4 3)) VALUE(REP)"
    },
    {
      "code": "CHGVAR VAR(%SST(*LDA 1 512)) VALUE(' ')"
    },
    {
      "code": "CHGVAR VAR(%BINARY(&A 1 2)) VALUE(20)"
    },
    {
      "code": "CHGVAR VAR(%BIN(&A 1 2)) VALUE(20)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/chgvar.htm",
    "version": "IBM i 7.4"
  }
}
