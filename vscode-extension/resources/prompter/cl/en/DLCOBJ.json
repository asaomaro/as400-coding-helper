    {
      "name": "SCOPE",
      "description": "Lock scope",
      "help": "Lock scope (SCOPE)\n\nSpecify the scope for this lock request.\n\nAll objects types supported by the OBJ parameter support job-scoped locks. All object types supported by the OBJ parameter support lock-space-scoped locks. For DDM objects with a lock-space-scope, the lock on the remote system is scoped to the job. To determine if an object type supports thread-scoped locks refer to the figure Object Types that Support Thread Scope Locks.\n\nThe lock scope must match the scope of the locks currently allocated for the job or thread.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*JOB",
          "value": "*JOB"
        },
        {
          "label": "*THREAD",
          "value": "*THREAD"
        },
