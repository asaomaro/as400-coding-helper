      "help": "Time format (TIMFMT)\n\nSpecifies the format used when accessing time result columns. For input time strings, the specified value is used to determine whether the time is specified in a valid format.\n\nNote: An input time string that uses the format *USA, *ISO, *EUR, or *JIS is always valid.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*HMS",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 8
      },
      "options": [
        {
          "label": "*HMS",
          "value": "*HMS"
        },
        {
          "label": "*USA",
          "value": "*USA"
        },
        {
          "label": "*ISO",
          "value": "*ISO"
        },
        {
          "label": "*EUR",
          "value": "*EUR"
        },
        {
          "label": "*JIS",
          "value": "*JIS"
        }
      ]
    },
    {
      "name": "TIMSEP",
      "description": "Time separator character",
      "help": "Time separator character (TIMSEP)\n\nSpecifies the separator used when accessing time result columns.\n\nNote: This parameter applies only when *HMS is specified for the Time format (TIMFMT) parameter.\n\nUse the Display Job (DSPJOB) command to determine the current time separator value for the job.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 8
      },
      "options": [
        {
          "label": "*JOB",
          "value": "*JOB"
        },
        {
          "label": "*BLANK",
          "value": "*BLANK"
        },
        {
          "label": "':'",
          "value": "':'"
        },
        {
          "label": "'.'",
          "value": "'.'"
        },
        {
          "label": "','",
          "value": "','"
        },
        {
          "label": "' '",
          "value": "' '"
        }
      ]
    },
    {
      "name": "DFTRDBCOL",
      "description": "Default collection",
      "help": "Default collection (DFTRDBCOL)\n\nSpecifies the name of the schema identifier used for the unqualified names of the tables, views, indexes, SQL packages, aliases, constraints, external programs, node groups, and triggers. This parameter applies only to static SQL statements.\n\n指定できる特殊値: *NONE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*NONE",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      }
    },
    {
      "name": "DECMPT",
      "description": "Decimal point",
      "help": "Decimal point (DECMPT)\n\nSpecifies the decimal point value used for numeric constants in SQL statements. This value is also used as the decimal point character when casting between character and numeric values.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*JOB",
          "value": "*JOB"
        },
        {
          "label": "*SYSVAL",
          "value": "*SYSVAL"
        },
        {
          "label": "*PERIOD",
          "value": "*PERIOD"
        },
        {
          "label": "*COMMA",
          "value": "*COMMA"
        }
      ]
    },
    {
      "name": "SRTSEQ",
      "description": "Sort sequence",
      "help": "Sort sequence (SRTSEQ)\n\nSpecifies the sort sequence table to be used for string comparisons in SQL statements.\n\nSingle values\n\nQualifier 1: Sort sequence\n\nQualifier 2: Library",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "singleValues": [
        "*JOB",
        "*LANGIDUNQ",
        "*LANGIDSHR",
        "*HEX"
      ],
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SRTSEQ",
          "description": "Sort sequence",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "defaultValue": "*JOB"
        }
      ]
    },
    {
      "name": "LANGID",
      "description": "Language id",
      "help": "Language id (LANGID)\n\nSpecifies the language identifier to be used when SRTSEQ(*LANGIDUNQ) or SRTSEQ(*LANGIDSHR) is specified.\n\n指定できる特殊値: *JOB",
      "inputType": "text",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      }
    },
    {
      "name": "OPTION",
      "description": "Source listing options",
      "help": "Source listing options (OPTION)\n\nSpecifies whether a listing is generated by the command.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NOLIST",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 8
      },
      "options": [
        {
          "label": "*NOLIST",
          "value": "*NOLIST"
        },
        {
          "label": "*LIST",
          "value": "*LIST"
        }
      ]
    },
    {
      "name": "PRTFILE",
      "description": "Print file",
      "help": "Print file (PRTFILE)\n\nSpecifies the printer device file to which the printout from the command is directed. The file must have a minimum length of 132 bytes. If a file with a record length of less than 132 bytes is specified, information is lost.\n\nQualifier 1: Print file\n\nQualifier 2: Library",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "PRTFILE_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "PRTFILE",
          "description": "Print file",
          "inputType": "text",
          "required": false,
          "defaultValue": "QSYSPRT",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ]
    },
    {
      "name": "SECLVLTXT",
      "description": "Second level text",
      "help": "Second level text (SECLVLTXT)\n\nSpecifies whether the second-level message text descriptions should be written to the output listing.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
      ]
    },
    {
      "name": "ALWCPYDTA",
      "description": "Allow copy of data",
      "help": "Allow copy of data (ALWCPYDTA)\n\nSpecifies whether a copy of the data can be used in a SELECT statement.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*OPTIMIZE",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*OPTIMIZE",
          "value": "*OPTIMIZE"
        },
        {
          "label": "*YES",
          "value": "*YES"
        },
        {
          "label": "*NO",
          "value": "*NO"
        }
      ]
    },
    {
      "name": "ALWBLK",
      "description": "Allow blocking",
      "help": "Allow blocking (ALWBLK)\n\nSpecifies whether the database manager can use record blocking and the extent to which blocking can be used for read-only cursors.\n\nSpecifying *ALLREAD:\n\nSpecifying *NONE:",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*ALLREAD",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*ALLREAD",
          "value": "*ALLREAD"
        },
        {
          "label": "*NONE",
          "value": "*NONE"
        },
        {
          "label": "*READ",
          "value": "*READ"
        }
      ]
    },
    {
      "name": "SQLCURRULE",
      "description": "SQL rules",
      "help": "SQL rules (SQLCURRULE)\n\nSpecifies the semantics used for SQL statements.\n\nHexadecimal constants are treated as character data.\n\nHexadecimal constants are treated as binary data.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*DB2",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*DB2",
          "value": "*DB2"
        },
        {
          "label": "*STD",
          "value": "*STD"
        }
      ]
    },
    {
      "name": "DECRESULT",
      "description": "Decimal result options",
      "help": "Decimal result options (DECRESULT)\n\nSpecifies the maximum precision, maximum scale, and minimum divide scale that should be used during decimal operations, such as decimal arithmetic. The specified limits only apply to NUMERIC and DECIMAL data types.\n\nElement 1: Maximum precision\n\nElement 2: Maximum scale\n\nElement 3: Minimum divide scale",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "DECRESULT_E1",
          "description": "Maximum precision",
          "inputType": "text",
          "required": false,
          "defaultValue": "31"
        },
        {
          "name": "DECRESULT_E2",
          "description": "Maximum scale",
          "inputType": "number",
          "required": false,
          "defaultValue": "31",
          "attributes": {
            "numericOnly": true
          }
        },
        {
          "name": "DECRESULT_E3",
          "description": "Minimum divide scale",
          "inputType": "number",
          "required": false,
          "defaultValue": "0",
          "attributes": {
            "numericOnly": true
          }
        }
      ]
    },
    {
      "name": "CONACC",
      "description": "Concurrent access resolution",
      "help": "Concurrent access resolution (CONACC)\n\nSpecifies how the database manager should handle record lock conflicts for data in the process of being updated.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*DFT",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 7
      },
      "options": [
        {
          "label": "*DFT",
          "value": "*DFT"
        },
        {
          "label": "*CURCMT",
          "value": "*CURCMT"
        },
        {
          "label": "*WAIT",
          "value": "*WAIT"
        }
      ]
    },
    {
      "name": "SYSTIME",
      "description": "System time sensitive",
      "help": "System time sensitive (SYSTIME)\n\nSpecifies whether references to system-period temporal tables in both static and dynamic SQL statements are affected by the value of the CURRENT TEMPORAL SYSTEM_TIME special register.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*YES",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*YES",
          "value": "*YES"
        },
        {
          "label": "*NO",
          "value": "*NO"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "RUNSQL SQL('insert into testlib/t1 values (1)')"
    },
    {
      "code": "RUNSQL SQL('CREATE TABLE qtemp.t1 AS (SELECT * FROM qsys2.systables WHERE table_schema = ''TESTLIB'') WITH DATA') COMMIT(*NONE) NAMING(*SQL)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/runsql.htm",
    "version": "IBM i 7.4"
  }
