        {
          "label": "*ALL",
          "value": "*ALL"
        },
        {
          "label": "*RS",
          "value": "*RS"
        },
        {
          "label": "*NONE",
          "value": "*NONE"
        },
        {
          "label": "*NC",
          "value": "*NC"
        },
        {
          "label": "*RR",
          "value": "*RR"
        }
      ],
      "positional": 2,
      "basic": true
    },
    {
      "name": "NAMING",
      "description": "Naming",
      "help": "Naming convention (NAMING)\n\nSpecifies the naming convention used for objects in SQL statements.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*SYS",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*SYS",
          "value": "*SYS"
        },
        {
          "label": "*SQL",
          "value": "*SQL"
        }
      ],
      "positional": 3,
      "basic": true
    },
    {
      "name": "DATFMT",
      "description": "Date format",
      "help": "Date format (DATFMT)\n\nSpecifies the format used when accessing date result columns. For input date strings, the specified value is used to determine whether the date is specified in a valid format.\n\nNote: An input date string that uses the format *USA, *ISO, *EUR, or *JIS is always valid.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 8
      },
      "options": [
        {
          "label": "*JOB",
          "value": "*JOB"
        },
        {
          "label": "*USA",
          "value": "*USA"
        },
        {
          "label": "*ISO",
          "value": "*ISO"
        },
        {
          "label": "*EUR",
          "value": "*EUR"
        },
        {
          "label": "*JIS",
          "value": "*JIS"
        },
        {
          "label": "*MDY",
          "value": "*MDY"
        },
        {
          "label": "*DMY",
          "value": "*DMY"
        },
        {
          "label": "*YMD",
          "value": "*YMD"
        },
        {
          "label": "*JUL",
          "value": "*JUL"
        }
      ]
    },
    {
      "name": "DATSEP",
      "description": "Date separator character",
      "help": "Date separator character (DATSEP)\n\nSpecifies the separator used when accessing date result columns.\n\nNote: This parameter applies only when *JOB, *MDY, *DMY, *YMD, or *JUL is specified for the Date format (DATFMT) parameter.\n\nUse the Display Job (DSPJOB) command to determine the current date separator value for the job.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 8
      },
      "options": [
        {
          "label": "*JOB",
          "value": "*JOB"
        },
        {
          "label": "*BLANK",
          "value": "*BLANK"
        },
        {
          "label": "'/'",
          "value": "'/'"
        },
        {
          "label": "'.'",
          "value": "'.'"
        },
        {
          "label": "','",
          "value": "','"
        },
        {
          "label": "'-'",
