{
  "keyword": "RUNSQL",
  "description": "Run SQL (RUNSQL)",
  "parameters": [
    {
      "name": "SQL",
      "description": "SQL",
      "help": "SQL (SQL)\n\nSpecifies a single Structured Query Language (SQL) statement to be run.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "positional": 1,
      "basic": true,
      "attributes": {
        "maxLength": 5000
      }
    },
    {
      "name": "COMMIT",
      "description": "Commitment control",
      "help": "Commitment control (COMMIT)\n\nSpecifies whether SQL statements are run under commitment control.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*CHG",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*CHG",
          "value": "*CHG"
        },
        {
          "label": "*UR",
          "value": "*UR"
        },
        {
          "label": "*CS",
          "value": "*CS"
