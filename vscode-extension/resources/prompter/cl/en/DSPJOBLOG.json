          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "defaultValue": "*"
        }
      ],
      "positional": 1,
      "basic": true
    },
    {
      "name": "OUTPUT",
      "description": "Output",
      "help": "Output (OUTPUT)\n\nSpecifies whether the output from the command is displayed at the requesting work station, printed with the job's spooled output or directed to a database file.\n\nWhen this value is used, both a primary and secondary output file can be produced. Any message filtering specified on the API is applied to the messages before they are written to the database. The database format (QMHPFT) of the output file is the same as that used in the IBM-supplied database file QAMHJLPR.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*",
          "value": "*"
        },
        {
          "label": "*PRINT",
          "value": "*PRINT"
        },
        {
          "label": "*APIDFN",
          "value": "*APIDFN"
        },
        {
          "label": "*OUTFILE",
          "value": "*OUTFILE"
        }
      ],
      "positional": 2,
      "basic": true,
      "valueMap": {
        "*APIDFN": "M",
        "*OUTFILE": "N",
        "*PRINT": "L"
      }
    },
    {
      "name": "OUTFILE",
      "description": "File to receive output",
      "help": "File to receive output (OUTFILE)\n\nSpecifies the database file to which the output of the command is directed. If the file does not exist, this command creates a database file in the specified library. If the file is created, the public authority for the file is the same as the create authority specified for the library in which the file is created. Use the Display Library Description (DSPLIBD) command to show the library's create authority.\n\nQualifier 1: File to receive output\n\nQualifier 2: Library",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "OUTFILE",
          "description": "File to receive output",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "promptControl": [
