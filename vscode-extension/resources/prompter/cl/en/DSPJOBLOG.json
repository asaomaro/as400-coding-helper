{
  "keyword": "DSPJOBLOG",
  "description": "Display Job Log (DSPJOBLOG)",
  "parameters": [
    {
      "name": "JOB",
      "description": "Job name",
      "help": "Job name (JOB)\n\nSpecifies the name of the job whose job log is to be shown.\n\nSingle values\n\nOther values\n\nA job identifier is a special value or a qualified name with up to three elements. For example:",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "JOB_Q3",
