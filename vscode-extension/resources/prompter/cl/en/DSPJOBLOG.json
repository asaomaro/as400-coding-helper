        }
      ],
      "valueMap": {
        "*ADD": "ADD",
        "*REPLACE": "REPLACE"
      }
    },
    {
      "name": "MSGF",
      "description": "Message file",
      "help": "Message file (MSGF)\n\nSpecifies how the message file used to format a predefined message is found. Messages sent using a message file in a specific library are always formatted using the message file from that library. Messages sent using a message file found using the library list can be formatted using the library list when the message was sent or the library list when the job log is displayed.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*MSG",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
