{
  "keyword": "CHGLIBL",
  "description": "Change Library List (CHGLIBL)",
  "parameters": [
    {
      "name": "LIBL",
      "description": "Libraries for current thread",
      "help": "指定できる特殊値: *SAME, *NONE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1,
      "maxOccurrences": 250,
      "basic": true
    },
    {
      "name": "CURLIB",
      "description": "Current library",
      "help": "指定できる特殊値: *SAME, *CRTDFT",
      "inputType": "text",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 2,
      "basic": true
    }
  ],
  "examples": [
    {
      "code": "CHGLIBL LIBL(ULIB10 ULIB15 QGPL)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/chglibl.htm",
    "version": "IBM i 7.4"
  }
