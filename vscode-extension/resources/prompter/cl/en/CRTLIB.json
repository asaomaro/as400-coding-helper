{
  "keyword": "CRTLIB",
  "description": "Create Library (CRTLIB)",
  "parameters": [
    {
      "name": "LIB",
      "description": "Library",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1
    },
    {
      "name": "TYPE",
      "description": "Library type",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*PROD",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*PROD",
          "value": "*PROD"
        },
        {
          "label": "*TEST",
          "value": "*TEST"
        }
      ],
      "positional": 2
    },
    {
      "name": "TEXT",
      "description": "Text 'description'",
      "help": "指定できる特殊値: *BLANK",
      "inputType": "text",
      "required": false,
      "defaultValue": "*BLANK",
      "attributes": {
        "characterSet": "upper"
      },
      "placeholder": "*BLANK"
    },
    {
      "name": "AUT",
      "description": "Authority",
      "help": "指定できる特殊値: *LIBCRTAUT, *CHANGE, *ALL, *USE, *EXCLUDE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*LIBCRTAUT",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "*LIBCRTAUT"
    },
    {
      "name": "ASP",
      "description": "ASP number",
      "help": "指定できる特殊値: *ASPDEV",
      "inputType": "text",
      "required": false,
      "defaultValue": "1",
      "attributes": {
        "characterSet": "upper"
      },
      "placeholder": "1"
    },
    {
      "name": "ASPDEV",
      "description": "ASP device",
      "help": "指定できる特殊値: *ASP, *ASPGRPPRI, *SYSTEM",
      "inputType": "text",
      "required": false,
      "defaultValue": "*ASP",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "*ASP"
    },
    {
      "name": "CRTAUT",
      "description": "Create authority",
      "help": "指定できる特殊値: *SYSVAL, *CHANGE, *ALL, *USE, *EXCLUDE",
      "inputType": "text",
      "required": false,
      "defaultValue": "*SYSVAL",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "*SYSVAL"
    },
    {
      "name": "CRTOBJAUD",
      "description": "Create object auditing",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*SYSVAL",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*SYSVAL",
          "value": "*SYSVAL"
        },
        {
          "label": "*NONE",
          "value": "*NONE"
        },
        {
          "label": "*USRPRF",
          "value": "*USRPRF"
        },
        {
          "label": "*CHANGE",
          "value": "*CHANGE"
        },
        {
          "label": "*ALL",
          "value": "*ALL"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "CRTLIB LIB(MYLIB) TEXT('My Production Library')"
    },
    {
      "code": "CRTLIB LIB(Z) TYPE(*TEST) AUT(*EXCLUDE) TEXT('This is a test library')"
    },
    {
      "code": "CRTLIB LIB(INVENTORY) ASPDEV(SALES) TEXT('Inventory Library on SALES ASP')"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/crtlib.htm",
    "version": "IBM i 7.4"
  }
}
