{
  "keyword": "WRKJOBD",
  "description": "Work with Job Descriptions (WRKJOBD)",
  "parameters": [
    {
      "name": "JOBD",
      "description": "Job description",
      "help": "Job description (JOBD)\n\nSpecifies the job descriptions to be shown on the Work with Job Descriptions display.\n\nThis is a required parameter.\n\nQualifier 1: Job description\n\nQualifier 2: Library\n\nAlthough the following Qxxx libraries are provided by IBM, they typically contain user data that changes frequently. Therefore, these libraries are considered user libraries and are also searched:",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALLUSR, *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "JOBD",
          "description": "Job description",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    }
  ],
  "examples": [
    {
      "code": "WRKJOBD JOBD(MYLIB/SPEC*)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/wrkjobd.htm",
    "version": "IBM i 7.4"
  }
}
