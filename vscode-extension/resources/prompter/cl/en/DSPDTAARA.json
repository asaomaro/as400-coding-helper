{
  "keyword": "DSPDTAARA",
  "description": "Display Data Area (DSPDTAARA)",
  "parameters": [
    {
      "name": "DTAARA",
      "description": "Data area",
      "help": "Data area (DTAARA)\n\nSpecifies the name and library of the data area whose attributes and values are to be displayed.\n\nThis is a required parameter.\n\nSingle values\n\nQualifier 1: Data area\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "singleValues": [
        "*LDA",
        "*GDA",
        "*PDA"
      ],
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "DTAARA",
          "description": "Data area",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1,
      "objectKind": "dataArea"
    },
    {
      "name": "OUTPUT",
      "description": "Output",
      "help": "Output (OUTPUT)\n\nSpecifies whether the output from the command is displayed at the requesting work station or printed with the job's spooled output.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*",
          "value": "*"
        },
        {
          "label": "*PRINT",
          "value": "*PRINT"
        }
      ],
      "positional": 2
    },
    {
      "name": "OUTFMT",
      "description": "Output format",
      "help": "Output format (OUTFMT)\n\nSpecifies the format in which the value of the data area is shown. In order to show the hexadecimal value of characters that cannot be shown, both character and hexadecimal representations of a character data area can be shown.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*CHAR",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*CHAR",
          "value": "*CHAR"
        },
        {
          "label": "*HEX",
          "value": "*HEX"
        }
      ]
    },
    {
      "name": "SYSTEM",
      "description": "System",
      "help": "System (SYSTEM)\n\nSpecifies whether the information provided is the data area on the local system (*LCL) or on the remote system (*RMT).",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*LCL",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*LCL",
          "value": "*LCL"
        },
        {
          "label": "*RMT",
          "value": "*RMT"
        }
      ],
      "valueMap": {
        "*LCL": "L",
        "*RMT": "R"
      }
    }
  ],
  "examples": [
    {
      "code": "DSPDTAARA DTAARA(HEXDATA) OUTPUT(*) OUTFMT(*HEX)"
    },
    {
      "code": "DSPDTAARA DTAARA(TIME) OUTPUT(*)"
    }
  ],
