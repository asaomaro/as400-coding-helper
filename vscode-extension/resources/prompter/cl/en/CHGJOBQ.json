{
  "keyword": "CHGJOBQ",
  "description": "Change Job Queue (CHGJOBQ)",
  "parameters": [
    {
      "name": "JOBQ",
      "description": "Job queue",
      "help": "Job queue (JOBQ)\n\nSpecifies the job queue that is to have its attributes changed.\n\nThis is a required parameter.\n\nQualifier 1: Job queue\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "JOBQ",
          "description": "Job queue",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "TEXT",
      "description": "Text 'description'",
      "help": "Text 'description' (TEXT)\n\nSpecifies the text that briefly describes the object.\n\n指定できる特殊値: *SAME, *BLANK",
      "inputType": "text",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 50
      }
    },
    {
      "name": "OPRCTL",
      "description": "Operator controlled",
      "help": "Operator controlled (OPRCTL)\n\nSpecifies whether a user with job control authority is allowed to control and make changes to jobs with entries on this job queue.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*SAME",
          "value": "*SAME"
        },
        {
          "label": "*YES",
          "value": "*YES"
        },
        {
          "label": "*NO",
          "value": "*NO"
        }
      ],
      "positional": 2
    },
    {
      "name": "AUTCHK",
      "description": "Authority to check",
      "help": "Authority to check (AUTCHK)\n\nSpecifies what type of authorities to the job queue allow the user to control the job queue by holding or releasing the queue. Users with some special authority may also be able to control the job queue.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*SAME",
          "value": "*SAME"
        },
        {
          "label": "*OWNER",
          "value": "*OWNER"
        },
        {
          "label": "*DTAAUT",
          "value": "*DTAAUT"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "CHGJOBQ JOBQ(QBATCH) OPRCTL(*NO)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/chgjobq.htm",
    "version": "IBM i 7.4"
  }
}
