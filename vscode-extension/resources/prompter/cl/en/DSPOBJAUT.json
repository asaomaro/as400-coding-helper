          },
          "options": [
            {
              "label": "*REPLACE",
              "value": "*REPLACE"
            },
            {
              "label": "*ADD",
              "value": "*ADD"
            }
          ]
        }
      ],
      "promptControl": [
        {
          "controlParameter": "OUTPUT",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "N"
            }
          ]
        }
      ],
      "valueMap": {
        "*ADD": "ADD",
        "*REPLACE": "REPLACE"
      }
    },
    {
      "name": "AUTTYPE",
      "description": "Authority type",
      "help": "Authority type (AUTTYPE)\n\nSpecifies whether object level authority, field level authority, or both object level and field level authority are displayed. Field level authority information only applies to *FILE objects.\n\nIf OUTPUT(*) is requested and the object is a file with field level authorities, the F16 key, Display Field Authorities, will be enabled on the display.\n\nThis value is only valid if *FILE is specified for the Object type (OBJTYPE) parameter.\n\nThis value is only valid if *FILE is specified for the Object type (OBJTYPE) parameter.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*OBJECT",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*OBJECT",
          "value": "*OBJECT"
        },
        {
          "label": "*FIELD",
          "value": "*FIELD"
        },
        {
          "label": "*ALL",
          "value": "*ALL"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "OBJTYPE",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "FILE"
            }
          ]
        }
      ],
      "valueMap": {
        "*ALL": "A",
        "*FIELD": "F",
        "*OBJECT": "O"
      }
    }
  ],
