      "positional": 3,
      "basic": true,
      "valueMap": {
        "*OUTFILE": "N",
        "*PRINT": "L"
      }
    },
    {
      "name": "OUTFILE",
      "description": "File to receive output",
      "help": "File to receive output (OUTFILE)\n\nSpecifies the database file to which the output of the command is directed. If the file does not exist, this command creates a database file in the specified library. If the file is created, the public authority for the file is the same as the create authority specified for the library in which the file is created. Use the Display Library Description (DSPLIBD) command to show the library's create authority.\n\nQualifier 1: File to receive output\n\nQualifier 2: Library\n\nNote: If a new file is created, the system uses QAOBJAUT in QSYS with a format name of QSYDSAUT as a model.\n\nIf AUTTYPE(*FIELD) is specified for a *FILE object and a new outfile is created, the system uses QAFLDAUT in QSYS with a format name of QSYDSFLD as a model.",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "singleValues": [
        "*NONE"
      ],
      "children": [
        {
          "name": "OUTFILE_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "OUTFILE",
          "description": "File to receive output",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "promptControl": [
        {
          "controlParameter": "OUTPUT",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "N"
            }
          ]
        }
      ],
      "objectKind": "file"
    },
    {
      "name": "OUTMBR",
      "description": "Output member options",
      "help": "Output member options (OUTMBR)\n\nSpecifies the name of the database file member that receives the output of the command.\n\nElement 1: Member to receive output\n\nElement 2: Replace or add records",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "OUTMBR_E1",
          "description": "Member to receive output",
          "help": "指定できる特殊値: *FIRST",
          "inputType": "text",
          "required": false,
          "defaultValue": "*FIRST",
          "attributes": {
