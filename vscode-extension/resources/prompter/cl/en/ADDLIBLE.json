{
  "keyword": "ADDLIBLE",
  "description": "Add Library List Entry (ADDLIBLE)",
  "parameters": [
    {
      "name": "LIB",
      "description": "Library",
      "help": "Library (LIB)\n\nSpecifies the library to be added to the user portion of the library list for the current thread. A maximum of 250 libraries may exist in the user portion of the library list. Only one library name is added at a time with this command.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1,
      "placeholder": "TESTLIB",
      "basic": true
    },
    {
      "name": "POSITION",
      "description": "Library list position",
      "help": "Library list position (POSITION)\n\nSpecifies the position in the user portion of the library list for the current thread where the library is inserted. This parameter can be specified as a single value or as a list of two elements.\n\nSingle values\n\nElement 1: List position\n\nElement 2: Reference library",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "singleValues": [
        "*FIRST",
        "*LAST"
      ],
      "children": [
        {
          "name": "RELATION",
          "description": "List position",
          "inputType": "dropdown",
          "required": false,
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*FIRST",
              "value": "*FIRST"
            },
            {
              "label": "*LAST",
              "value": "*LAST"
            },
            {
              "label": "*AFTER",
              "value": "*AFTER"
            },
            {
              "label": "*BEFORE",
              "value": "*BEFORE"
            },
            {
              "label": "*REPLACE",
              "value": "*REPLACE"
            }
          ],
          "defaultValue": "*FIRST"
        },
        {
          "name": "REFLIB",
          "description": "Reference library",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "REFLIB",
          "dependsOn": [
            {
              "parameter": "RELATION",
              "equalsAny": [
                "*AFTER",
                "*BEFORE",
                "*REPLACE"
              ],
              "effect": "required"
            },
            {
              "parameter": "RELATION",
              "equalsAny": [
                "*AFTER",
                "*BEFORE",
                "*REPLACE"
              ],
              "effect": "visible"
            }
          ]
        }
      ],
      "positional": 2,
      "basic": true
    }
  ],
  "examples": [
    {
      "code": "ADDLIBLE LIB(TESTLIB) POSITION(*LAST)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/addlible.htm",
    "version": "IBM i 7.4"
  }
}
