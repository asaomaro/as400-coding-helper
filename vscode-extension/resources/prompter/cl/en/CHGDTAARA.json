{
  "keyword": "CHGDTAARA",
  "description": "Change Data Area (CHGDTAARA)",
  "parameters": [
    {
      "name": "DTAARA",
      "description": "Data area specification",
      "help": "Data area specification (DTAARA)\n\nSpecifies the name and library of the data area whose value is being changed. It optionally specifies, for character data areas only, the starting position and length of the character string that is changed in the data area.\n\nThis is a required parameter.\n\nElement 1: Data area\n\nSingle values\n\nQualifier 1: Data area\n\nQualifier 2: Library\n\nElement 2: Substring specifications\n\nSingle values\n\nElement 1: Substring starting position\n\nElement 2: Substring length",
      "inputType": "group",
      "required": true,
      "groupKind": "elements",
      "children": [
        {
          "name": "DTAARA_E1",
          "description": "Data area",
          "inputType": "group",
          "required": false,
          "groupKind": "qualified",
          "singleValues": [
            "*LDA",
            "*GDA",
            "*PDA"
          ],
          "children": [
            {
              "name": "LIB",
              "description": "Library",
              "help": "指定できる特殊値: *LIBL, *CURLIB",
              "inputType": "text",
              "required": false,
              "defaultValue": "*LIBL",
              "attributes": {
                "characterSet": "upper",
                "maxLength": 10
              }
            },
            {
              "name": "DTAARA",
              "description": "Data area",
              "inputType": "text",
              "required": true,
              "attributes": {
                "characterSet": "upper",
                "maxLength": 10
              },
              "help": "指定できる特殊値: *LDA, *GDA, *PDA"
            }
          ]
        },
        {
          "name": "DTAARA_E2",
          "description": "Substring specifications",
          "inputType": "dropdown",
          "required": false,
          "defaultValue": "*ALL",
          "attributes": {
            "characterSet": "upper"
          },
          "options": [
            {
              "label": "*ALL",
              "value": "*ALL"
            }
          ]
        },
        {
          "name": "DTAARA_E1",
          "description": "Substring starting position",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          }
        },
        {
          "name": "DTAARA_DTAARA_E2",
          "description": "Substring length",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          }
        }
      ],
      "positional": 1,
      "basic": true
    },
    {
      "name": "VALUE",
      "description": "New value",
      "help": "New value (VALUE)\n\nSpecifies the new value stored in the data area. Specify a value that is valid for the data attributes specified in the data area's description. If *CHAR or *LGL was specified for the Type (TYPE) parameter of the Create Data Area (CRTDTAARA) command when the data area was created and the value specified here is numeric, the value must be enclosed in apostrophes. If *DEC was specified for the Type (TYPE) parameter of the CRTDTAARA command, the value must not be enclosed in apostrophes.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "positional": 2,
      "placeholder": "'NEWVALUE'",
      "basic": true,
      "attributes": {
        "maxLength": 3
      }
    }
  ],
  "examples": [
    {
      "code": "CHGDTAARA DTAARA(MYLIB/MYDATA) VALUE(GOODNIGHT)"
    },
    {
      "code": "CHGDTAARA DTAARA(PAYROLLSW) VALUE('0')"
    },
    {
      "code": "CHGDTAARA DTAARA(*LDA (5 4)) VALUE('TWO')"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/chgdtaara.htm",
    "version": "IBM i 7.4"
  }
}
