{
  "keyword": "DSPFD",
  "description": "Display File Description (DSPFD)",
  "parameters": [
    {
      "name": "FILE",
      "description": "File",
      "help": "File (FILE)\n\nSpecifies the name and library of the files.\n\nThis is a required parameter.\n\nThe possible values for file names are:\n\nQualifier 2: Library\n\nAlthough the following Qxxx libraries are provided by IBM, they typically contain user data that changes frequently. Therefore, these libraries are considered user libraries and are also searched:",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALLUSR, *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*LIBL"
        },
        {
          "name": "FILE",
          "description": "File",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": true,
