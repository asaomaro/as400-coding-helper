        {
          "parameter": "TOMBR",
          "relation": "EQ",
          "compareValue": "*FROMMBR"
        }
      ]
    },
    {
      "controlRelation": "SPCFD",
      "controlParameter": "SRCSEQ",
      "countRelation": "EQ",
      "count": 1,
      "messageId": "CPD2824",
