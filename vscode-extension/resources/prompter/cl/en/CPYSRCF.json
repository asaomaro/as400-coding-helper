{
  "keyword": "CPYSRCF",
  "description": "Copy Source File (CPYSRCF)",
  "parameters": [
    {
      "name": "FROMFILE",
      "description": "Data base source file",
      "help": "Data base source file (FROMFILE)\n\nSpecifies the database source file that contains the records to be copied.\n\nThis is a required parameter.\n\nQualifier 1: Data base source file\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "FROMFILE",
          "description": "Data base source file",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1,
      "basic": true,
      "objectKind": "file"
    },
    {
      "name": "TOFILE",
      "description": "To file",
      "help": "To file (TOFILE)\n\nSpecifies the file that receives the copied records.\n\nThis is a required parameter.\n\nSingle values\n\nQualifier 1: To file\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "singleValues": [
        "*PRINT"
      ],
      "children": [
        {
          "name": "TOFILE_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "TOFILE",
          "description": "To file",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 2,
      "basic": true,
      "valueMap": {
        "*PRINT": "*LIST"
      },
      "objectKind": "file"
    },
    {
      "name": "FROMMBR",
      "description": "From member",
      "help": "From member (FROMMBR)\n\nSpecifies the file member(s) copied from the from-file. A single member, a generic set of members, or all members in the from-file can be copied. Members are copied in alphabetical order.\n\nThis is a required parameter.\n\n指定できる特殊値: *FIRST, *ALL",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 3,
      "basic": true
    },
    {
      "name": "TOMBR",
      "description": "To member or label",
      "help": "Member (TOMBR)\n\nSpecifies the name of the file member that receives the copied records.\n\nIf *PRINT is specified for the To file (TOFILE) parameter, either *FIRST or *FROMMBR must be specified for this parameter.\n\nIf a member name or *FIRST was specified as a value for the FROMMBR parameter, then a member in the to-file with the same name receives the records copied. If *ALL or a generic member name is specified as a value for the FROMMBR parameter, each member in the from-file is copied into a member with the same name in the to-file. Records from one or more members (specified by the FROMMBR parameter) in the from-file are copied to the first member in the to-file.\n\n指定できる特殊値: *FROMMBR, *FIRST",
      "inputType": "text",
      "required": false,
      "defaultValue": "*FROMMBR",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 4,
      "basic": true,
      "valueMap": {
        "*FIRST": "*N"
      }
    },
    {
      "name": "TOMBRID",
      "description": "To member identifier",
      "help": "To member identifier (TOMBRID)\n\nSpecifies, for new members added to the to-file, whether the member level identifer will be generated or copied from the member level identifier of the member in the from-file.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*GEN",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*GEN",
          "value": "*GEN"
        },
        {
          "label": "*FROMMBR",
          "value": "*FROMMBR"
        }
      ],
      "basic": true
    },
    {
      "name": "MBROPT",
      "description": "Replace or add records",
      "help": "Replace or add records (MBROPT)\n\nSpecifies whether the new records replace or are added to the existing records.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*REPLACE",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*REPLACE",
          "value": "*REPLACE"
        },
        {
          "label": "*ADD",
          "value": "*ADD"
        }
      ],
      "positional": 5,
      "basic": true,
      "valueMap": {
        "*ADD": "A",
        "*REPLACE": "R"
      }
    },
    {
      "name": "SRCCHGDATE",
      "description": "Source change date",
      "help": "Source change date (SRCCHGDATE)\n\nSpecifies, for new members added to the to-file, or if MBROPT(*REPLACE) was specified, whether the 'Last source update date/time' will be a new date/time, or copied from the 'Last source update date/time' of the member in the from-file.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*FROMMBR",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*FROMMBR",
          "value": "*FROMMBR"
        },
        {
          "label": "*NEW",
          "value": "*NEW"
        }
      ],
      "basic": true
    },
    {
      "name": "TEXT",
      "description": "Text 'description'",
      "help": "Text 'description' (TEXT)\n\nSpecifies if the MBROPT(*REPLACE) was specified, whether the text describing the member will be copied from the from-member.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*SAME",
          "value": "*SAME"
        },
        {
          "label": "*FROMMBR",
          "value": "*FROMMBR"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "MBROPT",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "NE",
              "compareValue": "A"
            }
          ]
        }
      ],
      "valueMap": {
        "*FROMMBR": "F",
        "*SAME": "S"
      }
    },
    {
      "name": "SRCTYPE",
      "description": "Source type",
      "help": "Source type (SRCTYPE)\n\nSpecifies if the MBROPT(*REPLACE) was specified, whether the source type of the to-member will be copied from the from-member.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*SAME",
          "value": "*SAME"
        },
        {
          "label": "*FROMMBR",
          "value": "*FROMMBR"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "MBROPT",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "NE",
              "compareValue": "A"
            }
          ]
        }
      ],
      "valueMap": {
        "*FROMMBR": "F",
        "*SAME": "S"
      }
    },
    {
      "name": "SRCOPT",
      "description": "Source update options",
      "help": "Source update options (SRCOPT)\n\nSpecifies whether new values are assigned to the source sequence number and date fields when records from the from-file are copied to the to-file.\n\nSingle values\n\nOther values (up to 2 repetitions)",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*SAME",
          "value": "*SAME"
        },
        {
          "label": "*SEQNBR",
          "value": "*SEQNBR"
        },
        {
          "label": "*DATE",
          "value": "*DATE"
        }
      ],
      "maxOccurrences": 2,
      "valueMap": {
        "*DATE": "D",
        "*SAME": "S",
        "*SEQNBR": "N"
      }
    },
    {
      "name": "SRCSEQ",
      "description": "Source sequence numbering",
      "help": "Source sequence numbering (SRCSEQ)\n\nSpecifies, only when *SEQNBR is also specified for the Source update options (SRCOPT) parameter, the sequence number to be used in the first copied record and the value to be added to the initial sequence number to calculate the sequence number for each subsequent copied record. The maximum value for a sequence number is 9999.99; if a value is larger than this limit, additional records in the member are all assigned the sequence number 9999.99.\n\nElement 1: Starting sequence number\n\nElement 2: Increment number",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "SRCSEQ_E1",
          "description": "Starting sequence number",
          "inputType": "number",
          "required": false,
          "defaultValue": "1.00",
          "attributes": {
            "numericOnly": true
          }
        },
        {
          "name": "SRCSEQ_E2",
          "description": "Increment number",
          "inputType": "number",
          "required": false,
          "defaultValue": "1.00",
          "attributes": {
            "numericOnly": true
          }
        }
      ],
      "promptControl": [
        {
          "controlParameter": "SRCOPT",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "NE",
              "compareValue": "S"
            }
          ]
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "CPYSRCF FROMFILE(QGPL/QCLSRC) TOFILE(MYLIB/CLSRC) FROMMBR(PGMA)"
    },
    {
      "code": "CPYSRCF FROMFILE(QRPG/QRPGSRC) TOFILE(*PRINT) FROMMBR(INV*)"
    },
    {
      "code": "CPYSRCF FROMFILE(MYLIB/TXTSRC) TOFILE(QIDU/QTXTSRC) FROMMBR(*ALL) SRCOPT(*SEQNBR *DATE) SRCSEQ(1 .25)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/cpysrcf.htm",
    "version": "IBM i 7.4"
  },
