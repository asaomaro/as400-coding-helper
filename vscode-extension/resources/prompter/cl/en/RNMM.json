{
  "keyword": "RNMM",
  "description": "Rename Member (RNMM)",
  "parameters": [
    {
      "name": "FILE",
      "description": "Data base file",
      "help": "Data base file (FILE)\n\nSpecifies the database file (physical or logical) that contains the member to be renamed.\n\nThis is a required parameter.\n\nQualifier 1: Data base file\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "FILE",
          "description": "Data base file",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1,
      "basic": true,
      "objectKind": "file"
    },
    {
      "name": "MBR",
      "description": "Member",
      "help": "Member (MBR)\n\nSpecifies the physical or logical file member that is to be renamed.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 2,
      "basic": true
    },
    {
      "name": "NEWMBR",
      "description": "New member",
      "help": "New member (NEWMBR)\n\nSpecifies the new name to be given to the file member. The member remains in the same file. The new name must not be the same as the name specified on the Member (MBR) parameter. The new name must be unique in the file.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 3,
      "basic": true
    }
  ],
  "examples": [
    {
      "code": "RNMM FILE(ELEMENT) MBR(LEAD) NEWMBR(GOLD)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/rnmm.htm",
    "version": "IBM i 7.4"
  },
  "dependencies": [
    {
      "controlRelation": "ALWAYS",
      "countRelation": "EQ",
      "count": 0,
      "messageId": "CPD3234",
      "terms": [
        {
          "parameter": "MBR",
          "relation": "EQ",
          "compareParameter": "NEWMBR"
        }
      ]
    }
  ]
}
