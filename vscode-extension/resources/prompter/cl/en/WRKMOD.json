{
  "keyword": "WRKMOD",
  "description": "Work with Module (WRKMOD)",
  "parameters": [
    {
      "name": "MODULE",
      "description": "Module",
      "help": "Module (MODULE)\n\nSpecifies how to search for modules to be placed in the list. All modules with names that correspond to the specified parameter value, and for which the user has authority, are shown.\n\nThis is a required parameter.\n\nQualifier 1: Module\n\nQualifier 2: Library\n\nAlthough the following Qxxx libraries are provided by IBM, they typically contain user data that changes frequently. Therefore, these libraries are considered user libraries and are also searched:",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALLUSR, *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "MODULE",
          "description": "Module",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "MODATR",
      "description": "Module attribute",
      "help": "Module attribute (MODATR)\n\nSpecifies that a list of modules with the selected attribute is shown.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*ALL",
      "attributes": {
        "restricted": true,
        "characterSet": "upper",
        "maxLength": 10
      },
      "options": [
        {
          "label": "*ALL",
          "value": "*ALL"
        },
        {
          "label": "CBLLE",
          "value": "CBLLE"
        },
        {
          "label": "CLE",
          "value": "CLE"
        },
        {
          "label": "CLLE",
          "value": "CLLE"
        },
        {
          "label": "CPPLE",
          "value": "CPPLE"
        },
        {
          "label": "RPGLE",
          "value": "RPGLE"
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "WRKMOD MODULE(MYLIB/*ALL)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/wrkmod.htm",
    "version": "IBM i 7.4"
  }
}
