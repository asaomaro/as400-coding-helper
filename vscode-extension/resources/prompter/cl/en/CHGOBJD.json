      "name": "TEXT",
      "description": "Text 'description'",
      "help": "Text 'description' (TEXT)\n\nSpecifies the text that briefly describes the object.\n\n指定できる特殊値: *SAME, *BLANK",
      "inputType": "text",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "characterSet": "upper"
      },
