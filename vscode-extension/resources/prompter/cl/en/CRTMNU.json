      "description": "Menu",
      "help": "Menu (MENU)\n\nSpecifies the menu to be created.\n\nThis is a required parameter.\n\nQualifier 1: Menu\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
