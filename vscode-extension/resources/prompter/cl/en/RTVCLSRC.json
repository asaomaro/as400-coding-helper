{
  "keyword": "RTVCLSRC",
  "description": "Retrieve CL Source (RTVCLSRC)",
  "parameters": [
    {
      "name": "PGM",
      "description": "Program",
      "help": "Program (PGM)\n\nSpecifies the program object from which the original CL source is to be retrieved.\n\nNote: This parameter and the Service program (SRVPGM) parameter are mutually exclusive.\n\nQualifier 1: Program\n\nQualifier 2: Library",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "PGM",
          "description": "Program",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1,
      "basic": true,
      "objectKind": "program"
    },
    {
      "name": "SRVPGM",
      "description": "Service program",
      "help": "Service program (SRVPGM)\n\nSpecifies the service program object from which the original CL source is to be retrieved.\n\nNote: This parameter and the Program (PGM) parameter are mutually exclusive.\n\nQualifier 1: Program\n\nQualifier 2: Library",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "SRVPGM_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SRVPGM",
          "description": "Service program",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "basic": true
    },
    {
      "name": "MODULE",
      "description": "Module",
      "help": "Module (MODULE)\n\nSpecifies the CL module from which the original CL source is to be retrieved. If a value is specified for either the Program (PGM) parameter or the Service program (SRVPGM) parameter, this parameter identifies which CL module in the program or service program contains the CL source to be retrieved.\n\nNote: This parameter is ignored if an original program model (OPM) program object is specified for the Program (PGM) parameter.\n\nSingle values\n\nQualifier 1: Module\n\nQualifier 2: Library",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "singleValues": [
        "*PGM"
      ],
      "children": [
        {
          "name": "MODULE_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "MODULE",
          "description": "Module",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "defaultValue": "*PGM"
        }
      ],
      "basic": true
    },
    {
      "name": "SRCFILE",
      "description": "Source file",
      "help": "Source file (SRCFILE)\n\nSpecifies the database source file into which the CL source statements are to be written. This file must exist when the command is run.\n\nQualifier 1: Source file\n\nQualifier 2: Library",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "SRCFILE_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SRCFILE",
          "description": "Source file",
          "inputType": "text",
          "required": false,
          "defaultValue": "QCLSRC",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 2,
      "basic": true,
      "objectKind": "file"
    },
    {
      "name": "SRCMBR",
      "description": "Source member",
      "help": "Source member (SRCMBR)\n\nSpecifies the database source file member into which the CL source statements are to be written. If the member existed before the command was run, it is cleared before any source statements are written into it. If the member did not exist, it is created.\n\n指定できる特殊値: *PGM",
      "inputType": "text",
      "required": false,
      "defaultValue": "*PGM",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 3,
      "basic": true
    },
    {
      "name": "RTVINCSRC",
      "description": "Retrieve included source",
      "help": "Retrieve included source (RTVINCSRC)\n\nSpecifies whether or not to retrieve CL commands that were included by INCLUDE (Include CL Source) commands in the original source CL program.\n\nSpecifying *NO for this parameter will produce CL source which most closely matches the original CL source.\n\nSpecifying *YES for this parameter will produce CL source which most closely matches the full CL source used to create the CL program or module.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "restricted": true,
        "characterSet": "upper",
        "maxLength": 4
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
      ],
      "basic": true
    }
  ],
  "examples": [
    {
      "code": "RTVCLSRC PGM(JOHN1/TEXT1) SRCFILE(JOHN2) SRCMBR(JOHN3)"
    },
    {
      "code": "RTVCLSRC PGM(MYAPP1) SRCFILE(RTVAPPSRC) RTVINCSRC(*YES)"
    },
    {
      "code": "RTVCLSRC PGM(ACCTRCV) MODULE(GETACCT)"
    },
    {
      "code": "RTVCLSRC SRVPGM(AR_LIB/AR_PROCS) MODULE(GETCUST) SRCFILE(AR_SRC) RTVINCSRC(*YES)"
    },
    {
      "code": "RTVCLSRC MODULE(TOOLSLIB/MAILPDF) SRCFILE(TOOLSLIB/QCLSRC)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/rtvclsrc.htm",
    "version": "IBM i 7.4"
