          "value": "*EXECUTE"
        }
      ],
      "positional": 4,
      "maxOccurrences": 10,
      "placeholder": "*CHANGE",
      "basic": true
    },
    {
      "name": "AUTL",
      "description": "Authorization list",
      "help": "Authorization list (AUTL)\n\nSpecifies the authorization list that is revoked from the object specified for the Object (OBJ) parameter. If public authority in the object is *AUTL, it is changed to *EXCLUDE.\n\nNote: Either this parameter or the Users (USER) parameter must be specified. If this parameter is specified, the AUT parameter is ignored.",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "placeholder": "AUTL",
      "basic": true
    }
  ],
  "examples": [
    {
      "code": "RVKOBJAUT OBJ(ARLIB/PROG1) OBJTYPE(*PGM) USER(*ALL)"
    },
    {
      "code": "RVKOBJAUT OBJ(TSMITHPGM/MITHLIB) OBJTYPE(*PGM) USER(TMSMITH) AUT(*OBJEXIST)"
    },
    {
      "code": "RVKOBJAUT OBJ(FILEX) OBJTYPE(*FILE) USER(HEANDERSON) AUT(*DLT *UPD)"
    },
    {
      "code": "RVKOBJAUT OBJ(ARLIB/ARJOBD) OBJTYPE(*JOBD) USER(RLJOHNSON) AUT(*OBJEXIST)"
    },
    {
      "code": "RVKOBJAUT OBJ(FILEX) OBJTYPE(*FILE) AUTL(FILEUSERS)"
    }
  ],
