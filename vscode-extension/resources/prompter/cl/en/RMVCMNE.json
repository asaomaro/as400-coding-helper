{
  "keyword": "RMVCMNE",
  "description": "Remove Communications Entry (RMVCMNE)",
  "parameters": [
    {
      "name": "SBSD",
      "description": "Subsystem description",
      "help": "Subsystem description (SBSD)\n\nSpecifies the name and library of the subsystem description from which the communications entry is being removed.\n\nThis is a required parameter.\n\nQualifier 1: Subsystem description\n\nNote: The IBM-supplied object QSYSSBSD is not valid on this parameter.\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SBSD",
          "description": "Subsystem description",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "DEV",
      "description": "Device",
      "help": "Device (DEV)\n\nSpecifies the name of the device description, or the type of the device, for which the communications entry is being removed.\n\nNote: You must specify a value on either this parameter or the Remote location (RMTLOCNAME) parameter but not for both.\n\n指定できる特殊値: *ALL, *APPC, *ASYNC, *BSCEL, *INTRA, *RETAIL, *FINANCE, *SNUF",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 2,
      "valueMap": {
        "*FINANCE": "*FIN",
        "*RETAIL": "*RET"
      }
    },
    {
      "name": "RMTLOCNAME",
      "description": "Remote location",
      "help": "Remote location (RMTLOCNAME)\n\nSpecifies the name of the remote location for which the communications entry is removed.\n\nNote: You must specify either this parameter or the Device (DEV) parameter, but not both.",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      }
    },
    {
      "name": "MODE",
      "description": "Mode",
      "help": "Mode (MODE)\n\nSpecifies the name of the mode of the device specified on the Device (DEV) parameter or the remote location specified on the Remote location (RMTLOCNAME) parameter for which the communications entry is removed.\n\n指定できる特殊値: *ANY",
      "inputType": "text",
      "required": false,
      "defaultValue": "*ANY",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      }
    }
  ],
  "examples": [
    {
      "code": "RMVCMNE SBSD(LIB2/SBS1) DEV(COMDEV)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/rmvcmne.htm",
    "version": "IBM i 7.4"
  },
