{
  "keyword": "DSPJOBD",
  "description": "Display Job Description (DSPJOBD)",
  "parameters": [
    {
      "name": "JOBD",
      "description": "Job description",
      "help": "Job description (JOBD)\n\nSpecifies the name and library of the job description being displayed.\n\nThis is a required parameter.\n\nQualifier 1: Job description\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "JOBD",
          "description": "Job description",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "OUTPUT",
      "description": "Output",
      "help": "Output (OUTPUT)\n\nSpecifies whether the output from the command is displayed at the requesting work station or printed with the job's spooled output.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*",
          "value": "*"
        },
        {
          "label": "*PRINT",
          "value": "*PRINT"
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "DSPJOBD JOBD(MYLIB/SPECIAL)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/dspjobd.htm",
    "version": "IBM i 7.4"
  }
}
