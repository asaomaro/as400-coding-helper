{
  "keyword": "WRKF",
  "description": "Work with Files (WRKF)",
  "parameters": [
    {
      "name": "FILE",
      "description": "File",
      "help": "File (FILE)\n\nSpecifies the files to be shown on the Work with Files display.\n\nThis is a required parameter.\n\nQualifier 1: File\n\nQualifier 2: Library\n\nAlthough the following Qxxx libraries are provided by IBM, they typically contain user data that changes frequently. Therefore, these libraries are considered user libraries and are also searched:",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALLUSR, *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "FILE",
          "description": "File",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "FILEATR",
      "description": "File attributes",
      "help": "File attributes (FILEATR)\n\nSpecifies the type of file whose attributes are to be shown.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*ALL",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*ALL",
          "value": "*ALL"
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "WRKF FILE(X/PAY)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/wrkf.htm",
    "version": "IBM i 7.4"
  }
}
