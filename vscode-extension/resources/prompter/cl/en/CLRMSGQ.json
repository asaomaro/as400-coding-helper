{
  "keyword": "CLRMSGQ",
  "description": "Clear Message Queue (CLRMSGQ)",
  "parameters": [
    {
      "name": "MSGQ",
      "description": "Message queue",
      "help": "Message queue (MSGQ)\n\nSpecifies the message queue to be cleared. If a specific message queue name is specified with a library qualifier of *LIBL, only the first message queue found with that name is cleared.\n\nThis is a required parameter.\n\nQualifier 1: Message queue\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "MSGQ",
          "description": "Message queue",
          "help": "指定できる特殊値: *WRKSTN",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "CLEAR",
      "description": "Clear",
      "help": "Clear (CLEAR)\n\nSpecifies which messages to clear from the message queue.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*ALL",
      "attributes": {
        "restricted": true,
        "characterSet": "upper",
        "maxLength": 10
      },
      "options": [
        {
          "label": "*ALL",
          "value": "*ALL"
        },
        {
          "label": "*KEEPUNANS",
          "value": "*KEEPUNANS"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "CLRMSGQ MSGQ(*CURLIB/MQFIN) CLEAR(*ALL)"
    },
    {
      "code": "CLRMSGQ MSGQ(*CURLIB/MQFIN) CLEAR(*KEEPUNANS)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/clrmsgq.htm",
    "version": "IBM i 7.4"
  }
}
