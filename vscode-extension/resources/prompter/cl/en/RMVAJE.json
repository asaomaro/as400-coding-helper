{
  "keyword": "RMVAJE",
  "description": "Remove Autostart Job Entry (RMVAJE)",
  "parameters": [
    {
      "name": "SBSD",
      "description": "Subsystem description",
      "help": "Subsystem description (SBSD)\n\nSpecifies the name and library of the subsystem description from which the autostart job entry is being removed.\n\nThis is a required parameter.\n\nQualifier 1: Subsystem description\n\nNote: The IBM-supplied object QSYSSBSD is not valid on this parameter.\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SBSD",
          "description": "Subsystem description",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "JOB",
      "description": "Job name",
      "help": "Job name (JOB)\n\nSpecifies the simple name of the job that is started from the autostart job entry.\n\nThis is a required parameter.",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "RMVAJE SBSD(MYLIB/PAYROLL) JOB(INITIAL)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/rmvaje.htm",
    "version": "IBM i 7.4"
  }
}
