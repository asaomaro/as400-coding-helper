{
  "keyword": "DSPSBSD",
  "description": "Display Subsystem Description (DSPSBSD)",
  "parameters": [
    {
      "name": "SBSD",
      "description": "Subsystem description",
      "help": "Subsystem description (SBSD)\n\nSpecifies the name and library of the subsystem description being displayed.\n\nThis is a required parameter.\n\nQualifier 1: Subsystem description\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SBSD",
          "description": "Subsystem description",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    },
    {
      "name": "OUTPUT",
      "description": "Output",
      "help": "Output (OUTPUT)\n\nSpecifies whether the output from the command is displayed at the requesting work station or printed with the job's spooled output.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*",
          "value": "*"
        },
        {
          "label": "*PRINT",
          "value": "*PRINT"
        }
      ],
      "positional": 2
    }
  ],
  "examples": [
    {
      "code": "DSPSBSD SBSD(LIB6/ORDER) OUTPUT(*)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/dspsbsd.htm",
    "version": "IBM i 7.4"
  }
}
