{
  "keyword": "DSPFFD",
  "description": "Display File Field Description (DSPFFD)",
  "parameters": [
    {
      "name": "FILE",
      "description": "File",
      "help": "File (FILE)\n\nSpecifies the files for which field information is returned.\n\nThis is a required parameter.\n\nQualifier 1: File\n\nQualifier 2: Library\n\nAlthough the following Qxxx libraries are provided by IBM, they typically contain user data that changes frequently. Therefore, these libraries are considered user libraries and are also searched:",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALLUSR, *ALL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*LIBL"
        },
        {
          "name": "FILE",
          "description": "File",
          "help": "指定できる特殊値: *ALL",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "FILE"
        }
      ],
      "positional": 1,
      "basic": true,
      "objectKind": "file"
    },
    {
      "name": "OUTPUT",
      "description": "Output",
      "help": "Output (OUTPUT)\n\nSpecifies where the output from the command is sent.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper",
        "restricted": true,
        "maxLength": 10
      },
      "options": [
        {
          "label": "*",
          "value": "*"
        },
        {
          "label": "*PRINT",
          "value": "*PRINT"
        },
        {
          "label": "*OUTFILE",
          "value": "*OUTFILE"
        }
      ],
      "positional": 2,
      "basic": true,
      "valueMap": {
        "*OUTFILE": "*NONE"
      }
    },
    {
      "name": "OUTFILE",
      "description": "File to receive output",
      "help": "File to receive output (OUTFILE)\n\nSpecifies the database file to which the output of the command is directed. If the file does not exist, this command creates a database file in the specified library. If the file is created, the public authority for the file is the same as the create authority specified for the library in which the file is created. Use the Display Library Description (DSPLIBD) command to show the library's create authority.\n\nQualifier 1: File to receive output\n\nQualifier 2: Library\n\nNote: The outfile format must be the same as QWHDRFFD of system file QADSPFFD. For more information on the outfile format, refer to Database category in the IBM i Information Center at http://www.ibm.com/systems/i/infocenter/.",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "OUTFILE_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*LIBL"
        },
        {
          "name": "OUTFILE",
          "description": "File to receive output",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "FILE"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "OUTPUT",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "*NONE"
            }
          ]
        }
      ],
      "objectKind": "file"
    },
    {
      "name": "OUTMBR",
      "description": "Output member options",
      "help": "Output member options (OUTMBR)\n\nSpecifies the name of the database file member that receives the output of the command.\n\nElement 1: Member to receive output\n\nElement 2: Replace or add records",
      "inputType": "group",
      "required": false,
      "groupKind": "elements",
      "children": [
        {
          "name": "MEMBER",
          "description": "Member to receive output",
          "help": "指定できる特殊値: *FIRST",
          "inputType": "text",
          "required": false,
          "defaultValue": "*FIRST",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*FIRST"
        },
        {
          "name": "OPTION",
          "description": "Replace or add records",
          "inputType": "dropdown",
          "required": false,
          "defaultValue": "*REPLACE",
          "attributes": {
