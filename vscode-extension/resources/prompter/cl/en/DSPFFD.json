          },
          "options": [
            {
              "label": "*REPLACE",
              "value": "*REPLACE"
            },
            {
              "label": "*ADD",
              "value": "*ADD"
            }
          ]
        }
      ],
      "promptControl": [
        {
          "controlParameter": "OUTPUT",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "*NONE"
            }
          ]
        }
      ],
      "valueMap": {
        "*ADD": "A",
        "*REPLACE": "R"
      }
    },
    {
      "name": "SYSTEM",
      "description": "System",
      "help": "System (SYSTEM)\n\nSpecifies whether the information that is returned is about files on the local system or files on remote systems.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*LCL",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*LCL",
          "value": "*LCL"
        },
        {
          "label": "*RMT",
          "value": "*RMT"
        },
        {
          "label": "*ALL",
          "value": "*ALL"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "DSPFFD FILE(LIB1/FILE2)"
    },
    {
      "code": "DSPFFD FILE(*ALL/*ALL) SYSTEM(*ALL)"
    },
    {
      "code": "DSPFFD FILE(QGPL/FLDREF) OUTPUT(*OUTFILE) OUTFILE(QGPL/FLDREFX)"
    }
  ],
  "source": {
