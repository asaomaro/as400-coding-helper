{
  "keyword": "CHGCMDDFT",
  "description": "Change Command Default (CHGCMDDFT)",
  "parameters": [
    {
      "name": "CMD",
      "description": "Command",
      "help": "Command (CMD)\n\nSpecifies the command to be changed. The command can be a user-defined or an IBM-supplied command.\n\nQualifier 1: Command\n\nQualifier 2: Library",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "CMD",
          "description": "Command",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1,
      "basic": true
    },
    {
      "name": "NEWDFT",
      "description": "New default parameter string",
      "help": "New default parameter string (NEWDFT)\n\nSpecifies the parameter string, enclosed in apostrophes, that contains the new default values being assigned to a parameter, element, or qualifier if a value is not specified by the user when the command is processed. New default values can be specified only for those parameters, elements, or qualifiers that already have a default value.\n\n*N must be used as a place holder in a qualified name or in a list of values to take the place of elements or qualifiers that do not have existing default values. If the elements or qualifiers have default values but are not to be changed to a new default value, then *N or the existing default value can be used as the place holder in the list of values or the qualified name.\n\nNote: Checking between parameters and validity checking program processing is done when the command is run. Neither are performed during the changing of the default value.",
      "inputType": "text",
      "required": true,
      "positional": 2,
      "basic": true,
      "attributes": {
        "maxLength": 512
      }
    }
  ],
  "examples": [
    {
      "code": "CHGCMDDFT CMD(CRTPF) NEWDFT('AUT(*EXCLUDE)')"
    },
    {
      "code": "CHGCMDDFT CMD(USRQSYS/CRTCLPGM) NEWDFT('PGM(LIB1/*N) SRCFILE(LIB1/FILE1) LOG(*YES)')"
    },
    {
      "code": "CHGCMDDFT CMD(CRTPF) NEWDFT('MAXMBRS(*NOMAX)')"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/chgcmddft.htm",
    "version": "IBM i 7.4"
  },
