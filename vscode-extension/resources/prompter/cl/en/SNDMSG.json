{
  "keyword": "SNDMSG",
  "description": "Send Message (SNDMSG)",
  "parameters": [
    {
      "name": "MSG",
      "description": "Message text",
      "inputType": "text",
      "required": true,
      "positional": 1,
      "placeholder": "'メッセージ・テキスト'",
      "basic": true
    },
    {
      "name": "TOUSR",
      "description": "To user profile",
      "help": "指定できる特殊値: *SYSOPR, *ALLACT, *REQUESTER",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 3,
      "placeholder": "*SYSOPR",
      "basic": true
    },
    {
      "name": "TOMSGQ",
      "description": "To message queue",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "singleValues": [
        "*SYSOPR"
      ],
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*LIBL"
        },
        {
          "name": "TOMSGQ",
          "description": "To message queue",
          "help": "指定できる特殊値: *HSTLOG",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "QSYSOPR"
        }
      ],
      "positional": 2,
      "maxOccurrences": 50
    },
    {
      "name": "MSGTYPE",
      "description": "Message type",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*INFO",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*INFO",
          "value": "*INFO"
        },
        {
          "label": "*INQ",
          "value": "*INQ"
        }
      ],
      "positional": 4
    },
    {
      "name": "RPYMSGQ",
      "description": "Message queue to get reply",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "singleValues": [
        "*WRKSTN"
      ],
      "children": [
        {
          "name": "RPYMSGQ_LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "placeholder": "*LIBL"
        },
        {
          "name": "RPYMSGQ",
          "description": "Message queue to get reply",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          },
          "defaultValue": "*WRKSTN",
          "placeholder": "*WRKSTN"
        }
      ]
    },
    {
      "name": "CCSID",
      "description": "Coded character set ID",
      "help": "指定できる特殊値: *HEX, *JOB",
      "inputType": "text",
      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper"
      },
      "placeholder": "*JOB"
    }
  ],
  "examples": [
    {
      "code": "SNDMSG MSG('Do you want to update INV now?') TOUSR(JONES) MSGTYPE(*INQ) RPYMSGQ(SMITH)"
    },
    {
      "code": "SNDMSG MSG('Errors on PAYROLL cost me 1 hour of run time.') TOMSGQ(QHST)"
    },
    {
      "code": "SNDMSG MSG('Please make 2 copies of file LABORSTAT.') TOMSGQ(QSYSOPR)"
    },
    {
      "code": "SNDMSG MSG ('How long will the system be up today?') TOMSGQ(*SYSOPR) MSGTYPE(*INQ)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/sndmsg.htm",
    "version": "IBM i 7.4"
  }
}
