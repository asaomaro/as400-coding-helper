{
  "keyword": "DLTSRVPGM",
  "description": "Delete Service Program (DLTSRVPGM)",
  "parameters": [
    {
      "name": "SRVPGM",
      "description": "Service program",
      "help": "Service program (SRVPGM)\n\nSpecifies the service program to be deleted. A specific service program or a generic service program can be specified.\n\nThis is a required parameter.\n\nQualifier 1: Service program\n\nQualifier 2: Library\n\nAlthough the following Qxxx libraries are provided by IBM, they typically contain user data that changes frequently. Therefore, these libraries are considered user libraries and are also searched:",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALL, *ALLUSR",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "SRVPGM",
          "description": "Service program",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    }
  ],
  "examples": [
    {
      "code": "DLTSRVPGM SRVPGM(XYZ/S*)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/dltsrvpgm.htm",
    "version": "IBM i 7.4"
  }
