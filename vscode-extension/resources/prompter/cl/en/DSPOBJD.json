  "examples": [
    {
      "code": "DSPOBJD OBJ(X/PAY) OBJTYPE(*ALL)"
    },
    {
      "code": "DSPOBJD OBJ(X/PAY) OBJTYPE(*PGM) DETAIL(*FULL)"
