          "options": [
            {
              "label": "*ASP",
              "value": "*ASP"
            },
            {
              "label": "*ASPGRP",
              "value": "*ASPGRP"
            }
          ]
        }
      ],
      "basic": true
    },
    {
      "name": "OUTPUT",
      "description": "Output",
      "help": "Output (OUTPUT)\n\nSpecifies where the output from the command is sent.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*",
      "attributes": {
        "characterSet": "upper"
