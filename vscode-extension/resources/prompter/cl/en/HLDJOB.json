{
  "keyword": "HLDJOB",
  "description": "Hold Job (HLDJOB)",
  "parameters": [
    {
      "name": "JOB",
      "description": "Job name",
      "help": "Job name (JOB)\n\nSpecifies the name of the job being held.\n\nThis is a required parameter.\n\nQualifier 1: Job name\n\nQualifier 2: User\n\nQualifier 3: Number\n\nNote: If no user name or job number is specified, all jobs currently in the system are searched for the job name. If more than one occurrence of the specified name is found, a qualified job name must be provided either explicitly or through the selection display. Refer to the Duplicate job option (DUPJOBOPT) parameter for more information.",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "JOB_Q3",
          "description": "Number",
          "inputType": "number",
          "required": false,
          "attributes": {
            "numericOnly": true
          }
        },
        {
          "name": "JOB_Q2",
          "description": "User",
          "inputType": "text",
          "required": false,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "JOB",
          "description": "Job name",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1,
      "basic": true
    },
    {
      "name": "SPLFILE",
      "description": "Hold spooled files",
      "help": "Hold spooled files (SPLFILE)\n\nSpecifies whether spooled output files created by the job being held are also held.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "restricted": true,
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
      ],
      "positional": 2,
      "basic": true
    },
    {
      "name": "DUPJOBOPT",
      "description": "Duplicate job option",
      "help": "Duplicate job option (DUPJOBOPT)\n\nSpecifies the action taken when duplicate jobs are found by this command.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*SELECT",
      "attributes": {
        "restricted": true,
        "characterSet": "upper",
        "maxLength": 10
      },
      "options": [
        {
          "label": "*SELECT",
          "value": "*SELECT"
        },
        {
          "label": "*MSG",
          "value": "*MSG"
        }
      ]
    }
  ],
  "examples": [
    {
      "code": "HLDJOB JOB(PAYROLL) SPLFILE(*YES)"
    },
    {
      "code": "HLDJOB JOB(DEPTXYZ/PAYROLL)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/hldjob.htm",
    "version": "IBM i 7.4"
  }
}
