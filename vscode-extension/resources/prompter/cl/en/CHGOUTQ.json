      "name": "FCB",
      "description": "Forms Control Buffer",
      "help": "Forms Control Buffer (FCB)\n\nSpecifies the forms control buffer for files sent to a VM/MVS host system.\n\nNote: This parameter is valid only when CNNTYPE(*SNA) and DESTTYPE(*S390) are specified.\n\n指定できる特殊値: *NONE, *USRDTA, *PRTF, *SAME",
      "inputType": "text",
      "required": false,
      "defaultValue": "*SAME",
      "attributes": {
        "characterSet": "upper",
        "maxLength": 8
      },
      "promptControl": [
        {
          "controlParameter": "DESTTYPE",
          "countRelation": "EQ",
          "count": 1,
          "logicalRelation": "AND",
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "*S390"
            }
