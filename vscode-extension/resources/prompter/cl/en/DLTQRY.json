{
  "keyword": "DLTQRY",
  "description": "Delete Query (DLTQRY)",
  "parameters": [
    {
      "name": "QRY",
      "description": "Query",
      "help": "Query (QRY Parameter)\n\nSpecifies the qualified name of the query definition being deleted.\n\nThis is a required parameter.\n\nThe name of the query definition can be qualified by one of the following library values:\n\nAlthough the following Qxxx libraries are provided by IBM, they typically contain user data that changes frequently. Therefore, these libraries are considered user libraries and are also searched:",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALL, *ALLUSR",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "QRY",
          "description": "Query",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    }
  ],
  "examples": [
    {
      "code": "DLTQRY QRY(LIB1/MYDEF)"
    },
    {
      "code": "DLTQRY QRY(*ALL/MYDEF)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/en/ssw_ibm_i_74/cl/dltqry.htm",
    "version": "IBM i 7.4"
  }
}
