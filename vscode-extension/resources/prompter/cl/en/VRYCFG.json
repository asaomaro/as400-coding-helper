  "examples": [
    {
      "code": "VRYCFG CFGOBJ(LINE1) CFGTYPE(*LIN) STATUS(*OFF)"
    },
    {
      "code": "VRYCFG CFGOBJ(CONTROLLER1) CFGTYPE(*CTL) STATUS(*ON) RANGE(*OBJ)"
    },
    {
      "code": "VRYCFG CFGOBJ(DEVICE1) CFGTYPE(*DEV) STATUS(*ON) RANGE(*NET)"
    },
    {
      "code": "VRYCFG CFGOBJ(LINE1) CFGTYPE(*LIN) STATUS(*ON) RANGE(*OBJ) RESET(*YES)"
    },
    {
      "code": "VRYCFG CFGOBJ(LINE1) OJBTYPE(*LIN) STATUS(*ON) RANGE(*OBJ) VRYWAIT(*CFGOBJ)"
    },
    {
      "code": "VRYCFG CFGOBJ(LINE1) CFGTYPE(*LIN) STATUS(*ON) RANGE(*OBJ) VRYWAIT(80)"
    },
    {
      "code": "VRYCFG CFGOBJ(SERVER1) CFGTYPE(*NWS) STATUS(*ON)"
    },
    {
      "code": "VRYCFG CFGOBJ(MYLIBRARY) CFGTYPE(*MLBRSC) STATUS(*RESET) RSRCNAME(TAP01 TAP02)"
    },
    {
      "code": "VRYCFG CFGOBJ(MYLIBRARY) CFGTYPE(*MLBRSC) STATUS(*DEALLOCATE) RSRCNAME(OPT02)"
    },
    {
      "code": "VRYCFG CFGOBJ(IPCS*) CFGTYPE(*NWS) STATUS(*ON) SBMMLTJOB(*YES) JOBD(*LIBL/QBATCH)"
    },
    {
      "code": "VRYCFG CFGOBJ(SERVER1) CFGTYPE(*NWS) STATUS(*ON) GENPTHCERT(*YES)"
    },
    {
      "code": "VRYCFG CFGOBJ(SERVER1) CFGTYPE(*NWS) STATUS(*ON) RESETSYS(*YES)"
    }
  ],
