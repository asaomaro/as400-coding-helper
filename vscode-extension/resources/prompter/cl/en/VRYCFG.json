      "name": "RSRCNAME",
      "description": "Resource name",
      "help": "Resource name (RSRCNAME)\n\nSpecifies the drives within the media library device to be reset or reallocated.\n\nSingle values\n\nOther values (up to 16 repetitions)\n\n指定できる特殊値: *ALL",
      "inputType": "text",
      "required": false,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "maxOccurrences": 16,
      "promptControl": [
