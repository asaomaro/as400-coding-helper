          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "MLB"
            }
          ]
        }
      ]
    },
    {
      "name": "FRCVRYOFF",
      "description": "Forced vary off",
      "help": "Forced vary off (FRCVRYOFF)\n\nSpecifies whether inquiry messages for active jobs will be issued. This parameter is not allowed when STATUS(*ON) is specified.\n\nNotes:",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        },
        {
          "label": "*LOCK",
          "value": "*LOCK"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "STATUS",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "OF"
            },
            {
              "relation": "EQ",
              "compareValue": "DL"
            }
          ]
        }
      ],
      "valueMap": {
        "*LOCK": "LK",
        "*NO": "OF",
        "*YES": "ON"
      }
    },
    {
      "name": "SBMMLTJOB",
      "description": "Submit multiple jobs",
      "help": "Submit multiple jobs (SBMMLTJOB)\n\nSpecifies whether or not to submit multiple batch jobs to vary the specified network server or auxiliary storage pool (ASP) device description objects. This parameter is valid only when *NWS or *DEV is specified for the Type (CFGTYPE) parameter.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "CFGTYPE",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "NWS"
            },
            {
              "relation": "EQ",
              "compareValue": "DEV"
            }
          ]
        }
      ],
      "valueMap": {
        "*NO": "OF",
        "*YES": "ON"
      }
    },
    {
      "name": "JOBD",
      "description": "Job description",
      "help": "Job description (JOBD)\n\nSpecifies the job description to which multiple VRYCFG commands will be submitted in batch. This parameter is valid only when CFGTYPE is *NWS or *DEV and SBMMLTJOB is *YES.\n\nQualifier 1: Job description\n\nOther considerations are that the subsystem that allocates the job queue should not have the queue in a held state and the system should not be in a restricted state.\n\nQualifier 2: Library",
      "inputType": "group",
      "required": false,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "Library",
          "help": "指定できる特殊値: *LIBL",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "JOBD",
          "description": "Job description",
          "inputType": "text",
          "required": false,
          "defaultValue": "QBATCH",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ]
    },
    {
      "name": "GENPTHCERT",
      "description": "Generate path certificate",
      "help": "Generate path certificate (GENPTHCERT)\n\nSpecifies whether to generate a new set of certificates on a remote network server system. This parameter is valid only when CFGTYPE is *NWS and the STATUS is *ON.\n\nNote: You must have input/output system configuration (*IOSYSCFG) and security administrator (*SECADM) special authority to use this parameter value.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "STATUS",
          "countRelation": "EQ",
          "count": 1,
          "logicalRelation": "AND",
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "ON"
            }
          ]
        },
        {
          "controlParameter": "CFGTYPE",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "NWS"
            }
          ]
        }
      ],
      "valueMap": {
        "*NO": "OF",
        "*YES": "ON"
      }
    },
    {
      "name": "RESETSYS",
      "description": "Reset system",
      "help": "Reset system (RESETSYS)\n\nSpecifies whether to force a reset of the remote network server system, regardless of its current power state. This is an advanced function, caution is advised when this option is selected. This parameter is valid only when CFGTYPE is *NWS and the network server description is of type *ISCSI and the STATUS is *ON.\n\nNote: You must have all object (*ALLOBJ) special authority to use this parameter value.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NO",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*NO",
          "value": "*NO"
        },
        {
          "label": "*YES",
          "value": "*YES"
        }
      ],
      "promptControl": [
        {
          "controlParameter": "STATUS",
          "countRelation": "EQ",
          "count": 1,
          "logicalRelation": "AND",
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "ON"
            }
          ]
        },
        {
          "controlParameter": "CFGTYPE",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "NWS"
            }
          ]
        }
      ],
      "valueMap": {
        "*NO": "OF",
        "*YES": "ON"
      }
    }
