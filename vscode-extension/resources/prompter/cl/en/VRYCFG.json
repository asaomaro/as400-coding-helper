        }
      ]
    },
    {
      "name": "VRYWAIT",
      "description": "Vary on wait",
      "help": "Vary on wait (VRYWAIT)\n\nSpecifies whether the object is varied on asynchronously or synchronously. For synchronous vary on, specifies how long the system waits for the vary on to complete.\n\n指定できる特殊値: *CFGOBJ, *NOWAIT",
      "inputType": "text",
      "required": false,
      "defaultValue": "*CFGOBJ",
      "attributes": {
        "characterSet": "upper"
      },
      "promptControl": [
        {
          "controlParameter": "CFGTYPE",
          "countRelation": "EQ",
          "count": 1,
          "logicalRelation": "AND",
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "NWS"
            },
            {
              "relation": "EQ",
              "compareValue": "NWI"
            },
            {
              "relation": "EQ",
              "compareValue": "LIN"
            }
          ]
        },
        {
          "controlParameter": "STATUS",
          "countRelation": "EQ",
          "count": 1,
          "conditions": [
            {
              "relation": "EQ",
              "compareValue": "ON"
            }
          ]
        }
      ],
      "valueMap": {
        "*CFGOBJ": "-1",
        "*NOWAIT": "0"
      }
    },
