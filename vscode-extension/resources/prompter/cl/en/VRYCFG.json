{
  "keyword": "VRYCFG",
  "description": "Vary Configuration (VRYCFG)",
  "parameters": [
    {
      "name": "CFGOBJ",
      "description": "Configuration object",
      "help": "Configuration object (CFGOBJ)\n\nSpecifies the configuration objects to be varied.\n\nThis is a required parameter.\n\nSingle values\n\nOther values (up to 256 repetitions)\n\nNote: A generic name is specified as a character string that contains one or more characters followed by an asterisk (*). If a generic name is specified, then all objects that have names with the same prefix as the generic object name are selected.\n\n指定できる特殊値: *APPN, *PRVCFGTYPE",
      "inputType": "text",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "maxLength": 10
      },
      "positional": 1,
      "maxOccurrences": 256,
      "basic": true
    },
    {
      "name": "CFGTYPE",
      "description": "Type",
      "help": "Type (CFGTYPE)\n\nSpecifies the type of object to be varied.\n\nThis is a required parameter.",
      "inputType": "dropdown",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*NWS",
          "value": "*NWS"
        },
        {
          "label": "*LIN",
          "value": "*LIN"
        },
        {
          "label": "*CTL",
          "value": "*CTL"
        },
        {
          "label": "*DEV",
          "value": "*DEV"
        },
        {
          "label": "*MLBRSC",
          "value": "*MLBRSC"
        }
      ],
      "positional": 2,
      "basic": true,
      "valueMap": {
        "*CTL": "CTL",
        "*DEV": "DEV",
        "*LIN": "LIN",
        "*MLBRSC": "MLB",
        "*NWS": "NWS"
      }
    },
    {
      "name": "STATUS",
      "description": "Status",
      "help": "Status (STATUS)\n\nSpecifies whether to vary the object on or off.\n\nThis is a required parameter.\n\nNote: The drive resources must be specified for the Resource name (RSRCNAME) parameter.\n\nThe media library device must be varied on before this value can be specified.\n\nNote: The drive resources must be specified for the Resource name (RSRCNAME) parameter.\n\nNote: The drive resources must be specified for the Resource name (RSRCNAME) parameter.\n\nNote: The drive resources must be specified for the Resource name (RSRCNAME) parameter.",
      "inputType": "dropdown",
      "required": true,
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*ON",
          "value": "*ON"
        },
        {
          "label": "*OFF",
          "value": "*OFF"
        },
        {
          "label": "*RESET",
          "value": "*RESET"
        },
        {
          "label": "*ALLOCATE",
          "value": "*ALLOCATE"
        },
        {
          "label": "*UNPROTECTED",
          "value": "*UNPROTECTED"
        },
        {
          "label": "*DEALLOCATE",
          "value": "*DEALLOCATE"
        }
      ],
      "positional": 3,
      "basic": true,
      "valueMap": {
        "*ALLOCATE": "AL",
        "*DEALLOCATE": "DL",
        "*OFF": "OF",
        "*ON": "ON",
        "*RESET": "RS",
        "*UNPROTECTED": "UP"
      }
    },
    {
      "name": "RANGE",
      "description": "Range",
      "help": "Range (RANGE)\n\nSpecifies what configuration elements are varied.",
      "inputType": "dropdown",
      "required": false,
      "defaultValue": "*NET",
      "attributes": {
        "characterSet": "upper",
        "restricted": true
      },
      "options": [
        {
          "label": "*NET",
          "value": "*NET"
        },
        {
          "label": "*OBJ",
          "value": "*OBJ"
        }
