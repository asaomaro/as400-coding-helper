{
  "keyword": "DLTQRY",
  "description": "QUERY削除 (DLTQRY)",
  "help": "QUERY削除(DLTQRY)コマンドは，既存のQUERY定義をライブラリーから削除します。",
  "parameters": [
    {
      "name": "QRY",
      "description": "QUERY",
      "help": "削除するQUERY定義の修飾名を指定します。\n\nこれは必須パラメーターです。\n\nQUERY定義の名前は，次の1つのライブラリー値によって修飾することができます。\n\n次のQXXXライブラリーは弊社提供のものですが，これらには一般的によく変更されるユーザー・データが収められます。したがって，これらのライブラリーは「ユーザー・ライブラリー」と見なされ，検索されます。",
      "inputType": "group",
      "required": true,
      "groupKind": "qualified",
      "children": [
        {
          "name": "LIB",
          "description": "ライブラリー",
          "help": "指定できる特殊値: *LIBL, *CURLIB, *USRLIBL, *ALL, *ALLUSR",
          "inputType": "text",
          "required": false,
          "defaultValue": "*LIBL",
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        },
        {
          "name": "QRY",
          "description": "QUERY",
          "inputType": "text",
          "required": true,
          "attributes": {
            "characterSet": "upper",
            "maxLength": 10
          }
        }
      ],
      "positional": 1
    }
  ],
  "threadSafe": false,
  "environment": "すべての環境 (*ALL)",
  "examples": [
    {
      "code": "DLTQRY QRY(LIB1/MYDEF)"
    },
    {
      "code": "DLTQRY QRY(*ALL/MYDEF)"
    }
  ],
  "source": {
    "url": "https://www.ibm.com/docs/ja/ssw_ibm_i_74/cl/dltqry.htm",
    "version": "IBM i 7.4"
  }
}
