      "required": false,
      "defaultValue": "*JOB",
      "attributes": {
        "characterSet": "upper"
      },
      "options": [
        {
          "label": "*JOB",
          "value": "*JOB",
          "help": "ロックの有効範囲はジョブとなります。"
