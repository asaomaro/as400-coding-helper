{
  "keyword": "DCL",
  "description": "CL変数宣言（DCL）",
  "help": "CL プログラム/プロシージャーで使用する CL 変数を1つ宣言します。宣言コマンドは PGM の直後・他コマンドより前に置きます。",
  "parameters": [
    {
      "name": "VAR",
      "description": "CL変数名",
      "help": "宣言する CL 変数名を指定します（先頭は &。例 &COUNT）。",
      "inputType": "text",
      "required": true,
      "attributes": {
        "maxLength": 11
      },
      "placeholder": "&VAR"
    },
    {
      "name": "TYPE",
      "description": "タイプ",
      "help": "変数のデータ型を指定します。",
      "inputType": "dropdown",
      "required": true,
      "options": [
        { "label": "*DEC（パック10進）", "value": "*DEC" },
        { "label": "*CHAR（文字）", "value": "*CHAR" },
        { "label": "*LGL（論理 '0'/'1'）", "value": "*LGL" },
        { "label": "*INT（符号付き整数）", "value": "*INT" },
        { "label": "*UINT（符号なし整数）", "value": "*UINT" },
        { "label": "*PTR（ポインター）", "value": "*PTR" }
      ]
    },
    {
      "name": "STG",
      "description": "記憶域",
      "help": "変数の記憶域の割り当て方法。既定は *AUTO。",
      "inputType": "dropdown",
      "required": false,
      "options": [
        { "label": "*AUTO（自動）", "value": "*AUTO" },
        { "label": "*BASED（基底）", "value": "*BASED" },
        { "label": "*DEFINED（定義）", "value": "*DEFINED" }
      ]
    },
    {
      "name": "LEN",
      "description": "変数の長さ",
      "help": "変数の長さを指定します（型により意味が異なる）。要素1=長さ、要素2=小数点以下の桁数（*DEC のみ）。",
      "inputType": "group",
      "required": false,
      "children": [
        {
          "name": "LENGTH",
          "description": "長さ",
          "help": "変数の長さ（桁数/バイト数）。",
          "inputType": "number",
          "required": false,
          "placeholder": "10"
        },
        {
          "name": "DEC",
          "description": "小数点以下の桁数",
          "help": "*DEC の場合の小数点以下桁数。",
          "inputType": "number",
          "required": false,
          "placeholder": "0"
        }
      ]
    },
    {
      "name": "VALUE",
      "description": "初期値",
      "help": "変数の初期値。リテラルを指定します。",
      "inputType": "text",
      "required": false,
      "attributes": {
        "maxLength": 5000
      },
      "placeholder": "' '"
    },
    {
      "name": "BASPTR",
      "description": "基底ポインター変数",
      "help": "STG(*BASED) のとき、この変数の基底となるポインター CL 変数を指定します。",
      "inputType": "text",
      "required": false,
      "attributes": {
        "maxLength": 11
      },
      "placeholder": "&PTR"
    },
    {
      "name": "DEFVAR",
      "description": "変数で定義",
      "help": "STG(*DEFINED) のとき、定義のベースとなる CL 変数と位置を指定します。要素1=CL変数名、要素2=位置(1-32767、既定1)。",
      "inputType": "group",
      "required": false,
      "children": [
        {
          "name": "VAR",
          "description": "CL変数名",
          "help": "定義のベースとなる CL 変数。",
          "inputType": "text",
          "required": false,
          "attributes": { "maxLength": 11 },
          "placeholder": "&BASE"
        },
        {
          "name": "POS",
          "description": "位置",
          "help": "ベース変数内の開始位置（1-32767、既定1）。",
          "inputType": "number",
          "required": false,
          "placeholder": "1"
        }
      ]
    },
    {
      "name": "ADDRESS",
      "description": "アドレス",
      "help": "ポインター変数の初期アドレス。単一値 *NULL（既定）、または 要素1=CL変数名、要素2=オフセット(0-32766、既定0)。",
      "inputType": "group",
      "required": false,
      "children": [
        {
          "name": "VAR",
          "description": "CL変数名",
          "help": "アドレスのベースとなる CL 変数。",
          "inputType": "text",
          "required": false,
          "attributes": { "maxLength": 11 },
          "placeholder": "*NULL"
        },
        {
          "name": "OFFSET",
          "description": "オフセット",
          "help": "ベースからのオフセット（0-32766、既定0）。",
          "inputType": "number",
          "required": false,
          "placeholder": "0"
        }
      ]
    }
  ]
}
