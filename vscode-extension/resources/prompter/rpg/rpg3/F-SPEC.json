      "sourceStart": 16,
      "sourceLength": 1,
      "options": [
        { "label": "P（1次）", "value": "P" },
        { "label": "S（2次）", "value": "S" },
        { "label": "C（連鎖）", "value": "C" },
        { "label": "R（レコード・アドレス）", "value": "R" },
        { "label": "T（テーブル）", "value": "T" }
