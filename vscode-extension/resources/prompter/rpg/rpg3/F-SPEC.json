      "required": true,
      "sourceStart": 7,
      "sourceLength": 8,
      "attributes": { "characterSet": "upper", "maxLength": 8 },
      "placeholder": "MYFILE"
    },
    {
      "name": "FILETYPE",
      "description": "ファイル・タイプ",
      "help": "15桁目。I=入力、O=出力、U=更新。",
      "inputType": "dropdown",
      "required": true,
      "sourceStart": 15,
      "sourceLength": 1,
      "options": [
        { "label": "I（入力）", "value": "I" },
        { "label": "O（出力）", "value": "O" },
        { "label": "U（更新）", "value": "U" }
      ]
    },
    {
      "name": "FILEDESIG",
