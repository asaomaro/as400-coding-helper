{
  // PJ ルート（as400-coding-helper）を開いた状態で F5 起動する。
  // 拡張機能の実体は vscode-extension/ サブフォルダにあるので、そこを指す。
  // ルートを開いたままにするのは、docs/origin の生成スクリプトや検査が
  // ルート基準で動くため（拡張機能だけ開くと原典側に手が届かない）。
  "version": "0.2.0",
  "configurations": [
    {
      "name": "拡張機能を起動",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension",
        // 動作確認用のソースを開いた状態で立ち上げる。
        "${workspaceFolder}/docs/src"
      ],
      "outFiles": ["${workspaceFolder}/vscode-extension/out/**/*.js"],
      "preLaunchTask": "npm: compile - vscode-extension"
    }
  ]
}
